<local:OverlayPanelWindow x:Class="WaffleMeter.App.Wpf.BuffOverlayPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="전투 보조"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Width="Auto" Left="60" Top="200" FontFamily="Segoe UI">
    <local:OverlayPanelWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </local:OverlayPanelWindow.Resources>
    <!-- Background is transparent by default (just floating icons); the "투명 배경" setting turns on a panel
         background + border + placeholder so the window can be found and dragged when empty. The Border is
         hit-testable (Transparent, not null) so a drag can start anywhere on the overlay. -->
    <Border Background="{Binding PanelBackground}" BorderBrush="{Binding PanelBorderBrush}"
            BorderThickness="{Binding PanelBorderThickness}" CornerRadius="8" MouseLeftButtonDown="OnDragHandle" Padding="2">
      <Grid Background="Transparent" MinWidth="60" MinHeight="20">
        <TextBlock Text="버프 오버레이 (드래그해서 이동)" Foreground="#CCFFFFFF" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Margin="8,4" Visibility="{Binding EmptyVisibility}">
            <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.9"/></TextBlock.Effect>
        </TextBlock>
        <ItemsControl ItemsSource="{Binding Slots}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="3,0" ToolTip="{Binding Name}">
                        <StackPanel.LayoutTransform>
                            <!-- Uniform icon-size scale (from the 버프 알림 size setting), applied to the whole slot. -->
                            <ScaleTransform ScaleX="{Binding DataContext.IconScale, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            ScaleY="{Binding DataContext.IconScale, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                        </StackPanel.LayoutTransform>
                        <Grid Width="46" Height="46" HorizontalAlignment="Center">
                            <!-- Circular skill icon, clipped so the cooldown ring frames it cleanly (no overlap). -->
                            <Image Source="{Binding IconSource}" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.Clip><EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/></Image.Clip>
                            </Image>
                            <!-- Faint full-circle track so the icon always reads as framed. -->
                            <Ellipse Width="43" Height="43" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Stroke="#40000000" StrokeThickness="2.5"/>
                            <!-- Cooldown/duration ring: a bright arc that frames the icon and sweeps toward nothing as
                                 the buff runs out, so the border "disappears" as the timer drops. Fixed 46x46 canvas
                                 with absolute coords keeps the shrinking arc centered. -->
                            <Path Data="{Binding Ring}" Stroke="#FFE9B54A" StrokeThickness="2.5" Width="46" Height="46"
                                  Stretch="None" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <!-- accent dot when a party member applied the buff -->
                            <Ellipse Width="9" Height="9" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,4,0"
                                     Fill="{DynamicResource Skin.Accent}" Visibility="{Binding ByOther, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                        <TextBlock Text="{Binding RemainingText}"
                                   Foreground="{Binding DataContext.TextBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.95"/></TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>
</local:OverlayPanelWindow>
