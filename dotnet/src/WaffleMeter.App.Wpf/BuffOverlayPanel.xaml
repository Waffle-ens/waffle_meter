<local:OverlayPanelWindow x:Class="WaffleMeter.App.Wpf.BuffOverlayPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="전투 보조"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Width="Auto" Left="60" Top="200" FontFamily="Segoe UI">
    <local:OverlayPanelWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </local:OverlayPanelWindow.Resources>
    <Border CornerRadius="8" BorderThickness="1" Padding="8,6" MouseLeftButtonDown="OnDragHandle"
            Background="{DynamicResource Skin.PanelBg}" BorderBrush="{DynamicResource Skin.Border}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="버프 없음" Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" VerticalAlignment="Center"
                       Margin="4,2" Visibility="{Binding EmptyVisibility}"/>
            <ItemsControl ItemsSource="{Binding Slots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="46" Margin="2,0" Padding="2,2" CornerRadius="6"
                                Background="{DynamicResource Skin.RowBg}" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1"
                                ToolTip="{Binding Name}">
                            <StackPanel>
                                <Grid HorizontalAlignment="Center">
                                    <Image Source="{Binding IconSource}" Width="34" Height="34"/>
                                    <!-- subtle accent dot when the buff was applied by another player -->
                                    <Ellipse Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                                             Fill="{DynamicResource Skin.Accent}" Visibility="{Binding ByOther, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                                <TextBlock Text="{Binding RemainingText}" Foreground="{DynamicResource Skin.Fg}" FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</local:OverlayPanelWindow>
