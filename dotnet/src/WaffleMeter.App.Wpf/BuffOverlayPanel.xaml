<local:OverlayPanelWindow x:Class="WaffleMeter.App.Wpf.BuffOverlayPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="전투 보조"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Width="Auto" Left="60" Top="200" FontFamily="Segoe UI">
    <local:OverlayPanelWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </local:OverlayPanelWindow.Resources>
    <!-- No panel chrome: max transparency, just floating icons. The transparent Grid is hit-testable so a
         drag can start anywhere on the overlay (including the gaps between icons). -->
    <Grid Background="Transparent" MouseLeftButtonDown="OnDragHandle" Margin="2">
        <TextBlock Text="버프 없음" Foreground="#CCFFFFFF" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Margin="6,3" Visibility="{Binding EmptyVisibility}">
            <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.9"/></TextBlock.Effect>
        </TextBlock>
        <ItemsControl ItemsSource="{Binding Slots}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="3,0" ToolTip="{Binding Name}">
                        <Grid Width="40" Height="40" HorizontalAlignment="Center">
                            <!-- Circular skill icon, clipped so the cooldown ring frames it cleanly (no overlap). -->
                            <Image Source="{Binding IconSource}" Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.Clip><EllipseGeometry Center="17,17" RadiusX="17" RadiusY="17"/></Image.Clip>
                            </Image>
                            <!-- Faint full-circle track so the icon always reads as framed. -->
                            <Ellipse Width="37" Height="37" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Stroke="#40000000" StrokeThickness="2.5"/>
                            <!-- Cooldown/duration ring: a bright arc that frames the icon and sweeps toward nothing as
                                 the buff runs out, so the border "disappears" as the timer drops. Fixed 40x40 canvas
                                 with absolute coords keeps the shrinking arc centered. -->
                            <Path Data="{Binding Ring}" Stroke="#FFE9B54A" StrokeThickness="2.5" Width="40" Height="40"
                                  Stretch="None" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <!-- accent dot when a party member applied the buff -->
                            <Ellipse Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,3,3,0"
                                     Fill="{DynamicResource Skin.Accent}" Visibility="{Binding ByOther, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                        <TextBlock Text="{Binding RemainingText}" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.95"/></TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</local:OverlayPanelWindow>
