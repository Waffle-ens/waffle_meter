<local:OverlayPanelWindow x:Class="WaffleMeter.App.Wpf.SkillSettingsFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="표시할 스킬 선택"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="CanResize"
        SizeToContent="Manual" Width="340" Height="480" MinWidth="280" MinHeight="200" Left="40" Top="40" FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <!-- skill toggle chip: dim when off, accent border + opaque when on -->
        <Style x:Key="SkillChip" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" CornerRadius="4" Padding="5,2" BorderThickness="1" Opacity="0.42"
                                Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.SoftBorder}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="1.0"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Skin.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GroupMiniBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderThickness="1" Background="{DynamicResource Skin.PanelBg}" BorderBrush="{DynamicResource Skin.Border}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="8" Opacity="0.4" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource Skin.StatBg}" CornerRadius="8,8,0,0"
                    BorderBrush="{DynamicResource Skin.Border}" BorderThickness="0,0,0,1" MouseLeftButtonDown="OnDragHandle">
                <Grid Margin="12,8">
                    <TextBlock Text="표시할 스킬 선택" Foreground="{DynamicResource Skin.Fg}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <Button Content="&#xE8BB;" Click="OnCloseButton" ToolTip="닫기" HorizontalAlignment="Right" Style="{StaticResource HeaderCloseButton}"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Image Source="{Binding JobIcon}" Width="18" Height="18" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Job}" Foreground="{DynamicResource Skin.Fg}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding HasNormal, Converter={StaticResource BoolVis}}">
                                    <Grid Margin="0,0,0,3">
                                        <TextBlock Text="일반" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource GroupMiniBtn}" Content="전체 선택" Click="OnSelectAll"/>
                                            <Button Style="{StaticResource GroupMiniBtn}" Content="해제" Click="OnDeselectAll"/>
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding NormalChips}" Margin="0,0,0,4">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ToggleButton Style="{StaticResource SkillChip}" IsChecked="{Binding IsVisible, Mode=TwoWay}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Visibility="{Binding HasStigma, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="스티그마" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,3"/>
                                    <ItemsControl ItemsSource="{Binding StigmaChips}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ToggleButton Style="{StaticResource SkillChip}" IsChecked="{Binding IsVisible, Mode=TwoWay}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</local:OverlayPanelWindow>
