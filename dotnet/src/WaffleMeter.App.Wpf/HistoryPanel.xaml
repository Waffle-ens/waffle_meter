<local:OverlayPanelWindow x:Class="WaffleMeter.App.Wpf.HistoryPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="전투 기록"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        Width="320" Height="640" MaxHeight="640" MinWidth="260" MinHeight="160"
        Left="40" Top="40"
        FontFamily="Segoe UI">
    <Window.Resources>
        <local:FontFamilyConverter x:Key="FontConv"/>

        <!-- Replay: a round accent-tinted play button on the row, matching the meter's transport chrome.
             Only present on rows whose battle actually has a recording (see BattleHistoryRowViewModel). -->
        <Style x:Key="RowReplayButton" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="ToolTip" Value="이 전투 리플레이 보기"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="13" Background="#38000000"
                                BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1">
                            <TextBlock Text="▶" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"
                                       Margin="2,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Skin.AccentSoft}"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource Skin.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Skin.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="6" BorderThickness="1"
            Background="{DynamicResource Skin.PanelBg}"
            BorderBrush="{DynamicResource Skin.Border}"
            TextElement.FontFamily="{Binding Settings.FontFamily, Converter={StaticResource FontConv}}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="6" Opacity="0.32" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header (drag handle) -->
            <Border Grid.Row="0" Background="{DynamicResource Skin.StatBg}" CornerRadius="6,6,0,0"
                    BorderBrush="{DynamicResource Skin.Border}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnDragHandle">
                <Grid Margin="12,8">
                    <TextBlock Text="전투 기록" Foreground="{DynamicResource Skin.Fg}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <Button Content="&#xE8BB;" Click="OnCloseButton" ToolTip="닫기" HorizontalAlignment="Right" Style="{StaticResource HeaderCloseButton}"/>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1">
                <TextBlock Text="전투 기록이 없습니다" Foreground="{DynamicResource Skin.MutedFg}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,26" Visibility="{Binding EmptyVisibility}"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Margin="8,3" ClipToBounds="True" Cursor="Hand"
                                        Background="{DynamicResource Skin.StatBg}" MinHeight="52"
                                        MouseLeftButtonUp="OnRowClick">
                                    <Grid>
                                        <Border Background="{Binding BackgroundBrush}" CornerRadius="8"/>
                                        <Grid Margin="12,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Source="{Binding BossIcon}" Width="32" Height="32"
                                                   Opacity="{Binding IconOpacity}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MobName}" Foreground="White" FontWeight="Bold"
                                                           FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DateTimeText}" Foreground="#80FFFFFF" FontSize="11" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding DurationText}" Foreground="{Binding DurationBrush}"
                                                       FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <Button Grid.Column="3" Style="{StaticResource RowReplayButton}" Margin="10,0,0,0"
                                                    VerticalAlignment="Center" Visibility="{Binding ReplayVisibility}"
                                                    Click="OnReplayClick"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</local:OverlayPanelWindow>
