<Window x:Class="WaffleMeter.App.Wpf.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="상세내역"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="CanResize"
        Width="820" Height="600" MinWidth="520" MinHeight="320" Left="460" Top="40" FontFamily="Segoe UI">
    <Window.Resources>
        <local:RatioToStarConverter x:Key="RatioToStar"/>
        <local:FontFamilyConverter x:Key="FontConv"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="Stat" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="Head" TargetType="TextBlock" BasedOn="{StaticResource Stat}">
            <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
        </Style>

        <!-- Section expander styled to match the meter: a row-card header with a MDL2 chevron that flips
             on expand, our row-bg/hover, and a disabled dim. -->
        <Style x:Key="DetailExpander" TargetType="Expander">
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{DynamicResource Skin.RowBg}" BorderBrush="{DynamicResource Skin.SoftBorder}"
                                BorderThickness="1" CornerRadius="6">
                            <DockPanel>
                                <ToggleButton DockPanel.Dock="Top" Focusable="False" OverridesDefaultStyle="True" Cursor="Hand"
                                              Content="{TemplateBinding Header}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="hb" Background="Transparent" Padding="10,7" CornerRadius="6"
                                                    TextElement.Foreground="{DynamicResource Skin.Fg}" TextElement.FontWeight="SemiBold" TextElement.FontSize="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="chev" Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11" FontWeight="Normal" Foreground="{DynamicResource Skin.MutedFg}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="chev" Property="Text" Value="&#xE76C;"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="hb" Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="content" DockPanel.Dock="Top"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="content" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Skill-chain expand toggle (the +/- in the skill table) restyled as a clean MDL2 chevron. -->
        <Style x:Key="ChainToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="3">
                            <TextBlock x:Name="g" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                       Foreground="{DynamicResource Skin.MutedFg}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="g" Property="Text" Value="&#xE70D;"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                                <Setter TargetName="g" Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource Skin.PanelBg}" CornerRadius="8" Padding="12"
            TextElement.FontFamily="{Binding FontFamily, Converter={StaticResource FontConv}}">
        <DockPanel>
            <Grid DockPanel.Dock="Top" MouseLeftButtonDown="OnDragHandle" Background="Transparent" Margin="0,0,0,8">
                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Skin.Fg}" FontWeight="Bold" FontSize="14"/>
                <Button Content="&#xE8BB;" Click="OnClose" HorizontalAlignment="Right" Style="{StaticResource HeaderCloseButton}"/>
            </Grid>

            <!-- 8-cell summary grid -->
            <UniformGrid DockPanel.Dock="Top" Columns="4" Margin="0,0,0,10">
                <UniformGrid.Resources>
                    <Style TargetType="StackPanel"><Setter Property="Margin" Value="2"/></Style>
                </UniformGrid.Resources>
                <StackPanel><TextBlock Text="누적 피해량" Style="{StaticResource Head}" TextAlignment="Left"/><TextBlock Text="{Binding TotalDamageText}" Foreground="{Binding AmountBrush}" FontWeight="Bold"/></StackPanel>
                <StackPanel><TextBlock Text="피해량 기여도" Style="{StaticResource Head}" TextAlignment="Left"/><TextBlock Text="{Binding ContributionText}" Foreground="{Binding ContributionBrush}"/></StackPanel>
                <StackPanel><TextBlock Text="치명타 비율" Style="{StaticResource Head}" TextAlignment="Left"/><TextBlock Text="{Binding CritText}" Foreground="{DynamicResource Skin.Fg}"/></StackPanel>
                <StackPanel><TextBlock Text="강타 비율" Style="{StaticResource Head}" TextAlignment="Left"/><TextBlock Text="{Binding StrongText}" Foreground="{DynamicResource Skin.Fg}"/></StackPanel>
                <StackPanel><TextBlock Text="완벽 비율" Style="{StaticResource Head}" TextAlignment="Left"/><TextBlock Text="{Binding PerfectText}" Foreground="{DynamicResource Skin.Fg}"/></StackPanel>
                <StackPanel><TextBlock Text="백어택 비율" Style="{StaticResource Head}" TextAlignment="Left"/><TextBlock Text="{Binding BackText}" Foreground="{DynamicResource Skin.Fg}"/></StackPanel>
                <StackPanel><TextBlock Text="보스 막기비율" Style="{StaticResource Head}" TextAlignment="Left"/><TextBlock Text="{Binding ParryText}" Foreground="{DynamicResource Skin.Fg}"/></StackPanel>
                <StackPanel><TextBlock Text="전투시간" Style="{StaticResource Head}" TextAlignment="Left"/><TextBlock Text="{Binding CombatTimeText}" Foreground="{Binding DetailCombatTimeBrush}"/></StackPanel>
            </UniformGrid>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Expander Header="버프 가동률" IsEnabled="{Binding HasBuffs}" Style="{StaticResource DetailExpander}">
                        <ItemsControl ItemsSource="{Binding Buffs}" Margin="8,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Skin.MutedFg}" FontWeight="SemiBold" FontSize="11" Margin="0,2"/>
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1" ToolTip="{Binding Description}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="172"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="52"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                                <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Background="{Binding Brush}" CornerRadius="2"/>
                                                        </Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding RateText}" Style="{StaticResource Stat}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="디버프 가동률" IsEnabled="{Binding HasDebuffs}" Style="{StaticResource DetailExpander}">
                        <ItemsControl ItemsSource="{Binding Debuffs}" Margin="8,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Skin.MutedFg}" FontWeight="SemiBold" FontSize="11" Margin="0,2"/>
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1" ToolTip="{Binding Description}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="172"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="52"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                                <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Background="{Binding Brush}" CornerRadius="2"/>
                                                        </Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding RateText}" Style="{StaticResource Stat}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="스킬 피해량" IsExpanded="True" Style="{StaticResource DetailExpander}">
                        <StackPanel Margin="4,4">
                            <Border Background="{DynamicResource Skin.TableHeadBg}" CornerRadius="4" Margin="0,0,0,3">
                            <Grid Margin="2,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="스킬명" Style="{StaticResource Head}" TextAlignment="Left"/>
                                <TextBlock Grid.Column="2" Text="명중 횟수" Style="{StaticResource Head}"/>
                                <TextBlock Grid.Column="3" Text="치명타" Style="{StaticResource Head}"/>
                                <TextBlock Grid.Column="4" Text="강타" Style="{StaticResource Head}"/>
                                <TextBlock Grid.Column="5" Text="완벽" Style="{StaticResource Head}"/>
                                <TextBlock Grid.Column="6" Text="백어택" Style="{StaticResource Head}"/>
                                <TextBlock Grid.Column="7" Text="패리" Style="{StaticResource Head}"/>
                                <TextBlock Grid.Column="8" Text="누적 피해량" Style="{StaticResource Head}"/>
                            </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding Skills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <ToggleButton Grid.Column="0" IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                              Visibility="{Binding HasChildren, Converter={StaticResource BoolToVis}}"
                                                              Style="{StaticResource ChainToggle}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Merged.Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Merged.HitsText}" Style="{StaticResource Stat}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Merged.CritText}" Style="{StaticResource Stat}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Merged.StrongText}" Style="{StaticResource Stat}"/>
                                                <TextBlock Grid.Column="5" Text="{Binding Merged.PerfectText}" Style="{StaticResource Stat}"/>
                                                <TextBlock Grid.Column="6" Text="{Binding Merged.BackText}" Style="{StaticResource Stat}"/>
                                                <TextBlock Grid.Column="7" Text="{Binding Merged.ParryText}" Style="{StaticResource Stat}"/>
                                                <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Merged.DamageText}" Foreground="#FFB7791F"/>
                                                    <TextBlock Text="{Binding Merged.PercentText}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10" Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Height="3" Margin="20,1,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding Merged.BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                    <ColumnDefinition Width="{Binding Merged.BarRest, Converter={StaticResource RatioToStar}}"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Merged.BarBrush}" CornerRadius="1.5"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Children}" Margin="22,0,0,2"
                                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="120"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding HitsText}" Style="{StaticResource Stat}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding CritText}" Style="{StaticResource Stat}"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding StrongText}" Style="{StaticResource Stat}"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding PerfectText}" Style="{StaticResource Stat}"/>
                                                            <TextBlock Grid.Column="5" Text="{Binding BackText}" Style="{StaticResource Stat}"/>
                                                            <TextBlock Grid.Column="6" Text="{Binding ParryText}" Style="{StaticResource Stat}"/>
                                                            <TextBlock Grid.Column="7" Text="{Binding DamageText}" Foreground="#FFB7791F" TextAlignment="Right" FontSize="11"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
