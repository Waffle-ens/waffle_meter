<Window x:Class="WaffleMeter.App.Wpf.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="상세내역"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="CanResize"
        Width="980" Height="640" MinWidth="720" MinHeight="360" Left="380" Top="40" FontFamily="Segoe UI">
    <Window.Resources>
        <local:RatioToStarConverter x:Key="RatioToStar"/>
        <local:FontFamilyConverter x:Key="FontConv"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Value accents (fixed across skins — they carry meaning, not chrome): cyan reads "output",
             magenta marks 강타. Mirrors the stats site's table so the two read the same at a glance. -->
        <SolidColorBrush x:Key="ValueCyan" Color="#2DD4BF"/>
        <SolidColorBrush x:Key="ValueMagenta" Color="#F472B6"/>

        <!-- Damage-share fill behind a skill row. It fades to nothing rather than ending on an edge, so it reads
             as a heat cue instead of a selection box — the site spends a whole column on 비중 instead. -->
        <LinearGradientBrush x:Key="ShareFill" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#802DD4BF" Offset="0"/>
            <GradientStop Color="#4D2DD4BF" Offset="0.5"/>
            <GradientStop Color="#002DD4BF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Gauge gloss: a soft top-light + bottom shade over the fill, so the bar reads as a lit surface
             instead of a flat painted rectangle. -->
        <LinearGradientBrush x:Key="BarGloss" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4DFFFFFF" Offset="0"/>
            <GradientStop Color="#12FFFFFF" Offset="0.5"/>
            <GradientStop Color="#1A000000" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="Stat" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <!-- Table header cell -->
        <Style x:Key="Head" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Table numeric cell: right-aligned like the stats site, so digits line up column-wise. -->
        <Style x:Key="Cell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellBold" TargetType="TextBlock" BasedOn="{StaticResource Cell}">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SumLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="SumValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15.5"/>
        </Style>
        <Style x:Key="SumTile" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Skin.RowBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Skin.SoftBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="11,8"/>
        </Style>

        <!-- Tab strip: pill buttons instead of the classic tab headers (stats-site look). -->
        <Style x:Key="PillTabs" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <TabPanel DockPanel.Dock="Top" IsItemsHost="True" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Pill" TargetType="TabItem">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="p" CornerRadius="6" Margin="0,0,7,0" Padding="13,7"
                                Background="Transparent" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter x:Name="c" ContentSource="Header" VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource Skin.MutedFg}"
                                              TextElement.FontSize="12.5" TextElement.FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="p" Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="p" Property="Background" Value="{DynamicResource Skin.TabSelectedBg}"/>
                                <Setter TargetName="p" Property="BorderBrush" Value="{DynamicResource Skin.Accent}"/>
                                <Setter TargetName="c" Property="TextElement.Foreground" Value="{DynamicResource Skin.Fg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Skill-chain expand toggle: bordered +/- box (control-bg, accent glyph). -->
        <Style x:Key="ChainToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" CornerRadius="4" Background="{DynamicResource Skin.ControlBg}"
                                BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1">
                            <TextBlock x:Name="g" Text="+" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource Skin.Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="g" Property="Text" Value="&#x2212;"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 직접/지속 badge -->
        <Style x:Key="TypeBadge" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Skin.StatBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Skin.SoftBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Buff/debuff uptime table. Bound to a flat list of BuffRowVM; each row carries its section
             ("내 버프" / "파티원 버프" / "그 외", or the caster) as a subtitle, like the stats site. -->
        <DataTemplate x:Key="UptimeTable">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel>
                <Border Background="{DynamicResource Skin.TableHeadBg}" CornerRadius="5" Margin="0,0,0,5">
                    <Grid Margin="10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="이름" Style="{StaticResource Head}" TextAlignment="Left"/>
                        <TextBlock Grid.Column="1" Text="가동률" Style="{StaticResource Head}"/>
                    </Grid>
                </Border>
                    <ItemsControl ItemsSource="{Binding}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="5" Padding="10,6" Margin="0,1" Background="{DynamicResource Skin.RowBg}"
                                        ToolTip="{Binding Description}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding IconSource}" Width="24" Height="24" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="12.5" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Subtitle}" Visibility="{Binding SubtitleVisibility}"
                                                           Foreground="{DynamicResource Skin.MutedFg}" FontSize="10.5" Margin="0,1,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Inset track + gradient fill under a gloss, so the gauge reads as a lit bar. -->
                                        <Grid Grid.Column="1" Height="11" VerticalAlignment="Center" Margin="12,0">
                                            <Border Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.SoftBorder}"
                                                    BorderThickness="1" CornerRadius="5.5"/>
                                            <Grid Margin="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                    <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding BarBrush}" CornerRadius="4.5">
                                                    <Border CornerRadius="4.5" Background="{StaticResource BarGloss}"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="{Binding RateText}" Style="{StaticResource CellBold}" Foreground="{Binding RateBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
              </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource Skin.PanelBg}" CornerRadius="8" Padding="12"
            TextElement.FontFamily="{Binding FontFamily, Converter={StaticResource FontConv}}">
        <DockPanel>
            <Grid DockPanel.Dock="Top" MouseLeftButtonDown="OnDragHandle" Background="Transparent" Margin="0,0,0,10">
                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Skin.Fg}" FontWeight="Bold" FontSize="14"/>
                <Button Content="&#xE8BB;" Click="OnClose" HorizontalAlignment="Right" Style="{StaticResource HeaderCloseButton}"/>
            </Grid>

            <!-- Stat tiles: label above value, 5 per row (stats-site layout). -->
            <UniformGrid DockPanel.Dock="Top" Columns="5" Margin="0,0,0,10">
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="총 피해" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding TotalDamageText}" Style="{StaticResource SumValue}" Foreground="{Binding AmountBrush}"/></StackPanel></Border>
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="DPS" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding DpsText}" Style="{StaticResource SumValue}" Foreground="{StaticResource ValueCyan}"/></StackPanel></Border>
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="기여도" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding ContributionText}" Style="{StaticResource SumValue}" Foreground="{Binding ContributionBrush}"/></StackPanel></Border>
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="타수" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding HitsText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="전투시간" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding CombatTimeText}" Style="{StaticResource SumValue}" Foreground="{Binding DetailCombatTimeBrush}"/></StackPanel></Border>

                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="치명" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding CritText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="강타" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding StrongText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="완벽" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding PerfectText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="후방" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding BackText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border Style="{StaticResource SumTile}"><StackPanel><TextBlock Text="막기" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding ParryText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
            </UniformGrid>

            <Grid>
                <TextBlock Text="이 전투에는 표시할 데이터가 없어요." Visibility="{Binding NoDataVisibility}"
                           Foreground="{DynamicResource Skin.MutedFg}" FontSize="13" Panel.ZIndex="1"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>

                <TabControl x:Name="Tabs" Style="{StaticResource PillTabs}">
                    <!-- ══════════════ 스킬 ══════════════ -->
                    <TabItem Style="{StaticResource Pill}">
                        <TabItem.Header>스킬</TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                          <StackPanel>
                            <Border Background="{DynamicResource Skin.TableHeadBg}" CornerRadius="5" Margin="0,0,0,5">
                                <Grid Margin="10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="150"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="66"/>
                                        <ColumnDefinition Width="66"/>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="58"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="스킬" Style="{StaticResource Head}" TextAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="유형" Style="{StaticResource Head}" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="타수" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="3" Text="치명" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="4" Text="강타" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="5" Text="완벽" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="6" Text="후방" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="7" Text="패리" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="8" Text="DPS" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="9" Text="평균" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="10" Text="누적" Style="{StaticResource Head}"/>
                                    <TextBlock Grid.Column="11" Text="비중" Style="{StaticResource Head}"/>
                                </Grid>
                            </Border>
                                <ItemsControl ItemsSource="{Binding Skills}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,1">
                                                <!-- The row's damage share is a faint fill behind it, so ranking reads
                                                     without spending a column on a bar (as the stats site does). -->
                                                <Border CornerRadius="5" Background="{DynamicResource Skin.RowBg}" ClipToBounds="True">
                                                    <Grid>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding Merged.BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                                <ColumnDefinition Width="{Binding Merged.BarRest, Converter={StaticResource RatioToStar}}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Background="{StaticResource ShareFill}"/>
                                                        </Grid>
                                                        <Grid Margin="10,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" MinWidth="150"/>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="52"/>
                                                                <ColumnDefinition Width="58"/>
                                                                <ColumnDefinition Width="58"/>
                                                                <ColumnDefinition Width="58"/>
                                                                <ColumnDefinition Width="58"/>
                                                                <ColumnDefinition Width="54"/>
                                                                <ColumnDefinition Width="66"/>
                                                                <ColumnDefinition Width="66"/>
                                                                <ColumnDefinition Width="72"/>
                                                                <ColumnDefinition Width="58"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Grid Width="22" Margin="0,0,4,0">
                                                                    <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                                  Visibility="{Binding HasChildren, Converter={StaticResource BoolToVis}}"
                                                                                  Style="{StaticResource ChainToggle}"/>
                                                                </Grid>
                                                                <Image Source="{Binding Merged.IconSource}" Width="24" Height="24" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Merged.Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="13" FontWeight="SemiBold"
                                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <Border Grid.Column="1" Style="{StaticResource TypeBadge}">
                                                                <TextBlock Text="{Binding Merged.TypeText}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10.5"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="2" Text="{Binding Merged.HitsText}" Style="{StaticResource Cell}"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding Merged.CritText}" Style="{StaticResource CellBold}" Foreground="{StaticResource ValueCyan}"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding Merged.StrongText}" Style="{StaticResource CellBold}" Foreground="{StaticResource ValueMagenta}"/>
                                                            <TextBlock Grid.Column="5" Text="{Binding Merged.PerfectText}" Style="{StaticResource Cell}"/>
                                                            <TextBlock Grid.Column="6" Text="{Binding Merged.BackText}" Style="{StaticResource Cell}"/>
                                                            <TextBlock Grid.Column="7" Text="{Binding Merged.ParryText}" Style="{StaticResource Cell}"/>
                                                            <TextBlock Grid.Column="8" Text="{Binding Merged.DpsText}" Style="{StaticResource Cell}"/>
                                                            <TextBlock Grid.Column="9" Text="{Binding Merged.AvgText}" Style="{StaticResource Cell}"/>
                                                            <TextBlock Grid.Column="10" Text="{Binding Merged.DamageText}" Style="{StaticResource CellBold}" Foreground="{StaticResource ValueCyan}"/>
                                                            <TextBlock Grid.Column="11" Text="{Binding Merged.PercentText}" Style="{StaticResource CellBold}" Foreground="{StaticResource ValueCyan}"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <!-- chain children: indented, accent left rail -->
                                                <ItemsControl ItemsSource="{Binding Children}" Margin="0,1,0,0"
                                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="5" Padding="10,4" Margin="26,1,0,0" BorderThickness="2,0,0,0"
                                                                    BorderBrush="{DynamicResource Skin.Accent}" Background="{DynamicResource Skin.RowHover}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" MinWidth="124"/>
                                                                        <ColumnDefinition Width="56"/>
                                                                        <ColumnDefinition Width="52"/>
                                                                        <ColumnDefinition Width="58"/>
                                                                        <ColumnDefinition Width="58"/>
                                                                        <ColumnDefinition Width="58"/>
                                                                        <ColumnDefinition Width="58"/>
                                                                        <ColumnDefinition Width="54"/>
                                                                        <ColumnDefinition Width="66"/>
                                                                        <ColumnDefinition Width="66"/>
                                                                        <ColumnDefinition Width="72"/>
                                                                        <ColumnDefinition Width="58"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <Image Source="{Binding IconSource}" Width="20" Height="20" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="12.5"
                                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <Border Grid.Column="1" Style="{StaticResource TypeBadge}">
                                                                        <TextBlock Text="{Binding TypeText}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="2" Text="{Binding HitsText}" Style="{StaticResource Cell}" FontSize="12"/>
                                                                    <TextBlock Grid.Column="3" Text="{Binding CritText}" Style="{StaticResource Cell}" FontSize="12" Foreground="{StaticResource ValueCyan}"/>
                                                                    <TextBlock Grid.Column="4" Text="{Binding StrongText}" Style="{StaticResource Cell}" FontSize="12" Foreground="{StaticResource ValueMagenta}"/>
                                                                    <TextBlock Grid.Column="5" Text="{Binding PerfectText}" Style="{StaticResource Cell}" FontSize="12"/>
                                                                    <TextBlock Grid.Column="6" Text="{Binding BackText}" Style="{StaticResource Cell}" FontSize="12"/>
                                                                    <TextBlock Grid.Column="7" Text="{Binding ParryText}" Style="{StaticResource Cell}" FontSize="12"/>
                                                                    <TextBlock Grid.Column="8" Text="{Binding DpsText}" Style="{StaticResource Cell}" FontSize="12"/>
                                                                    <TextBlock Grid.Column="9" Text="{Binding AvgText}" Style="{StaticResource Cell}" FontSize="12"/>
                                                                    <TextBlock Grid.Column="10" Text="{Binding DamageText}" Style="{StaticResource Cell}" FontSize="12" Foreground="{StaticResource ValueCyan}"/>
                                                                    <TextBlock Grid.Column="11" Text="{Binding PercentText}" Style="{StaticResource Cell}" FontSize="12" Foreground="{StaticResource ValueCyan}"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                          </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ══════════════ 버프 업타임 ══════════════ -->
                    <TabItem Style="{StaticResource Pill}" IsEnabled="{Binding HasBuffs}">
                        <TabItem.Header>버프 업타임</TabItem.Header>
                        <ContentControl Content="{Binding Buffs}" ContentTemplate="{StaticResource UptimeTable}"/>
                    </TabItem>

                    <!-- ══════════════ 디버프 업타임 ══════════════ -->
                    <TabItem Style="{StaticResource Pill}" IsEnabled="{Binding HasDebuffs}">
                        <TabItem.Header>디버프 업타임</TabItem.Header>
                        <ContentControl Content="{Binding Debuffs}" ContentTemplate="{StaticResource UptimeTable}"/>
                    </TabItem>

                </TabControl>
            </Grid>
        </DockPanel>
    </Border>
</Window>
