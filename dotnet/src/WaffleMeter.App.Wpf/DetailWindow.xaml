<Window x:Class="WaffleMeter.App.Wpf.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="상세내역"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="CanResize"
        Width="820" Height="600" MinWidth="520" MinHeight="320" Left="460" Top="40" FontFamily="Segoe UI">
    <Window.Resources>
        <local:RatioToStarConverter x:Key="RatioToStar"/>
        <local:FontFamilyConverter x:Key="FontConv"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="Stat" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
        <Style x:Key="Head" TargetType="TextBlock" BasedOn="{StaticResource Stat}">
            <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
        </Style>

        <!-- Section expander styled to match the meter: a row-card header with a MDL2 chevron that flips
             on expand, our row-bg/hover, and a disabled dim. -->
        <Style x:Key="DetailExpander" TargetType="Expander">
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{DynamicResource Skin.RowBg}" BorderBrush="{DynamicResource Skin.SoftBorder}"
                                BorderThickness="1" CornerRadius="6">
                            <DockPanel>
                                <ToggleButton DockPanel.Dock="Top" Focusable="False" OverridesDefaultStyle="True" Cursor="Hand"
                                              Content="{TemplateBinding Header}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="hb" Background="Transparent" Padding="10,7" CornerRadius="6"
                                                    TextElement.Foreground="{DynamicResource Skin.Fg}" TextElement.FontWeight="SemiBold" TextElement.FontSize="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="chev" Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11" FontWeight="Normal" Foreground="{DynamicResource Skin.MutedFg}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="chev" Property="Text" Value="&#xE76C;"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="hb" Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="content" DockPanel.Dock="Top"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="content" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Skill-chain expand toggle: dev's bordered +/- box (control-bg, accent glyph). -->
        <Style x:Key="ChainToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" CornerRadius="4" Background="{DynamicResource Skin.ControlBg}"
                                BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1">
                            <TextBlock x:Name="g" Text="+" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource Skin.Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="g" Property="Text" Value="&#x2212;"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Skill-table damage cell: a proportional gradient bar with the damage + (%) overlaid right (dev). -->
        <Style x:Key="SkillStatCell" TargetType="TextBlock" BasedOn="{StaticResource Stat}">
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource Skin.PanelBg}" CornerRadius="8" Padding="12"
            TextElement.FontFamily="{Binding FontFamily, Converter={StaticResource FontConv}}">
        <DockPanel>
            <Grid DockPanel.Dock="Top" MouseLeftButtonDown="OnDragHandle" Background="Transparent" Margin="0,0,0,8">
                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Skin.Fg}" FontWeight="Bold" FontSize="14"/>
                <Button Content="&#xE8BB;" Click="OnClose" HorizontalAlignment="Right" Style="{StaticResource HeaderCloseButton}"/>
            </Grid>

            <!-- 8-cell summary grid (dev: bordered cards, larger value text to fill the row) -->
            <UniformGrid DockPanel.Dock="Top" Columns="4" Margin="0,0,0,10">
                <UniformGrid.Resources>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource Skin.RowBg}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource Skin.SoftBorder}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CornerRadius" Value="6"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Padding" Value="12,9"/>
                    </Style>
                    <Style x:Key="SumLabel" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                    </Style>
                    <Style x:Key="SumValue" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="16"/>
                    </Style>
                </UniformGrid.Resources>
                <Border><StackPanel><TextBlock Text="누적 피해량" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding TotalDamageText}" Style="{StaticResource SumValue}" Foreground="{Binding AmountBrush}"/></StackPanel></Border>
                <Border><StackPanel><TextBlock Text="피해량 기여도" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding ContributionText}" Style="{StaticResource SumValue}" Foreground="{Binding ContributionBrush}"/></StackPanel></Border>
                <Border><StackPanel><TextBlock Text="치명타 비율" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding CritText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border><StackPanel><TextBlock Text="강타 비율" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding StrongText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border><StackPanel><TextBlock Text="완벽 비율" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding PerfectText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border><StackPanel><TextBlock Text="백어택 비율" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding BackText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border><StackPanel><TextBlock Text="보스 막기비율" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding ParryText}" Style="{StaticResource SumValue}"/></StackPanel></Border>
                <Border><StackPanel><TextBlock Text="전투시간" Style="{StaticResource SumLabel}"/><TextBlock Text="{Binding CombatTimeText}" Style="{StaticResource SumValue}" Foreground="{Binding DetailCombatTimeBrush}"/></StackPanel></Border>
            </UniformGrid>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Expander Header="버프 가동률" IsEnabled="{Binding HasBuffs}" Style="{StaticResource DetailExpander}">
                        <ItemsControl ItemsSource="{Binding Buffs}" Margin="8,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">
                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Skin.MutedFg}" FontWeight="SemiBold" FontSize="12.5" Margin="0,4"/>
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3" ToolTip="{Binding Description}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="172"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="52"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <Image Source="{Binding IconSource}" Width="19" Height="19" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="12.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Grid Grid.Column="1" Height="11" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                                <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Background="{Binding Brush}" CornerRadius="2"/>
                                                        </Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding RateText}" Style="{StaticResource Stat}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="디버프 가동률" IsEnabled="{Binding HasDebuffs}" Style="{StaticResource DetailExpander}">
                        <ItemsControl ItemsSource="{Binding Debuffs}" Margin="8,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">
                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Skin.MutedFg}" FontWeight="SemiBold" FontSize="12.5" Margin="0,4"/>
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3" ToolTip="{Binding Description}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="172"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="52"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <Image Source="{Binding IconSource}" Width="19" Height="19" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="12.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Grid Grid.Column="1" Height="11" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                                <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Background="{Binding Brush}" CornerRadius="2"/>
                                                        </Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding RateText}" Style="{StaticResource Stat}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="스킬 피해량" IsExpanded="True" Style="{StaticResource DetailExpander}">
                        <StackPanel Margin="4,4">
                            <Border Background="{DynamicResource Skin.TableHeadBg}" CornerRadius="4" Margin="0,0,0,4">
                            <Grid Margin="8,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="스킬명" Style="{StaticResource Head}" TextAlignment="Left"/>
                                <TextBlock Grid.Column="1" Text="명중 횟수" Style="{StaticResource Head}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="치명타" Style="{StaticResource Head}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="강타" Style="{StaticResource Head}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="완벽" Style="{StaticResource Head}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="백어택" Style="{StaticResource Head}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="패리" Style="{StaticResource Head}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="7" Text="누적 피해량" Style="{StaticResource Head}" TextAlignment="Center"/>
                            </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding Skills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,1">
                                            <!-- main (merged) skill row: [± toggle][icon][name] | stats | proportional damage bar -->
                                            <Border CornerRadius="4" Padding="8,5" Background="{DynamicResource Skin.RowBg}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="150"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Grid Width="22" Margin="0,0,6,0">
                                                        <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                      Visibility="{Binding HasChildren, Converter={StaticResource BoolToVis}}"
                                                                      Style="{StaticResource ChainToggle}"/>
                                                    </Grid>
                                                    <Image Source="{Binding Merged.IconSource}" Width="25" Height="25" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Merged.Name}" Foreground="{DynamicResource Skin.Fg}" FontSize="13.5"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Merged.HitsText}" Style="{StaticResource SkillStatCell}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Merged.CritText}" Style="{StaticResource SkillStatCell}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Merged.StrongText}" Style="{StaticResource SkillStatCell}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Merged.PerfectText}" Style="{StaticResource SkillStatCell}"/>
                                                <TextBlock Grid.Column="5" Text="{Binding Merged.BackText}" Style="{StaticResource SkillStatCell}"/>
                                                <TextBlock Grid.Column="6" Text="{Binding Merged.ParryText}" Style="{StaticResource SkillStatCell}"/>
                                                <Grid Grid.Column="7" Height="27" Margin="6,0,0,0">
                                                    <Border CornerRadius="5" ClipToBounds="True">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding Merged.BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                                <ColumnDefinition Width="{Binding Merged.BarRest, Converter={StaticResource RatioToStar}}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Background="{Binding Merged.BarBrush}"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0">
                                                        <TextBlock Text="{Binding Merged.DamageText}" Foreground="{DynamicResource Skin.Fg}" FontWeight="Bold" FontSize="12.5"/>
                                                        <TextBlock Text="{Binding Merged.PercentText, StringFormat=({0})}" Foreground="{DynamicResource Skin.Fg}" Opacity="0.75" FontSize="11" Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                            </Border>
                                            <!-- chain children: indented, accent left rail, smaller icon -->
                                            <ItemsControl ItemsSource="{Binding Children}" Margin="0,1,0,0"
                                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="4" Padding="8,4" Margin="24,1,0,0" BorderThickness="2,0,0,0"
                                                                BorderBrush="{DynamicResource Skin.Accent}" Background="{DynamicResource Skin.RowHover}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="48"/>
                                                                <ColumnDefinition Width="48"/>
                                                                <ColumnDefinition Width="48"/>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="48"/>
                                                                <ColumnDefinition Width="150"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Image Source="{Binding IconSource}" Width="21" Height="21" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="12.5"
                                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding HitsText}" Style="{StaticResource SkillStatCell}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding CritText}" Style="{StaticResource SkillStatCell}"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding StrongText}" Style="{StaticResource SkillStatCell}"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding PerfectText}" Style="{StaticResource SkillStatCell}"/>
                                                            <TextBlock Grid.Column="5" Text="{Binding BackText}" Style="{StaticResource SkillStatCell}"/>
                                                            <TextBlock Grid.Column="6" Text="{Binding ParryText}" Style="{StaticResource SkillStatCell}"/>
                                                            <Grid Grid.Column="7" Height="22" Margin="6,0,0,0">
                                                                <Border CornerRadius="4" ClipToBounds="True">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                                            <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" Background="{Binding BarBrush}"/>
                                                                    </Grid>
                                                                </Border>
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0">
                                                                    <TextBlock Text="{Binding DamageText}" Foreground="{DynamicResource Skin.Fg}" FontSize="11.5"/>
                                                                    <TextBlock Text="{Binding PercentText, StringFormat=({0})}" Foreground="{DynamicResource Skin.Fg}" Opacity="0.7" FontSize="10.5" Margin="5,0,0,0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
