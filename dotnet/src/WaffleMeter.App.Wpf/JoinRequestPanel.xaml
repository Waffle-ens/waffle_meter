<local:OverlayPanelWindow x:Class="WaffleMeter.App.Wpf.JoinRequestPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="파티 신청"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        Width="300" Height="360" MinWidth="240" MinHeight="150"
        Left="40" Top="40"
        FontFamily="Segoe UI">
    <Window.Resources>
        <local:RatioToStarConverter x:Key="RatioToStar"/>
        <local:FontFamilyConverter x:Key="FontConv"/>
    </Window.Resources>
    <Border CornerRadius="6" BorderThickness="1"
            Background="{DynamicResource Skin.PanelBg}"
            BorderBrush="{DynamicResource Skin.Border}"
            TextElement.FontFamily="{Binding Settings.FontFamily, Converter={StaticResource FontConv}}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="6" Opacity="0.32" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header (drag handle) -->
            <Border Grid.Row="0" Background="{DynamicResource Skin.StatBg}" CornerRadius="6,6,0,0"
                    BorderBrush="{DynamicResource Skin.Border}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnDragHandle">
                <Grid Margin="12,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="파티 신청" Foreground="{DynamicResource Skin.Fg}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.Border}" BorderThickness="1"
                                CornerRadius="4" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CountText}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="11"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE713;" Click="OnSettingsButton" ToolTip="표시할 스킬 선택" Style="{StaticResource HeaderIconButton}" Margin="0,0,2,0"/>
                        <Button Content="&#xE8BB;" Click="OnCloseButton" ToolTip="닫기" Style="{StaticResource HeaderCloseButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1">
                <TextBlock Text="파티 신청이 없습니다" Foreground="{DynamicResource Skin.MutedFg}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,22" Visibility="{Binding EmptyVisibility}"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Margin="8,3" BorderThickness="1"
                                        Background="{Binding CardBrush}" BorderBrush="{Binding BorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 4px left accent bar -->
                                        <Border Grid.Column="0" Background="{Binding AccentBrush}" CornerRadius="6,0,0,6"/>
                                        <StackPanel Grid.Column="1" Margin="8,6">
                                            <!-- name + power -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Image Grid.Column="0" Source="{Binding JobIcon}" Width="24" Height="24"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Nickname}" Foreground="{DynamicResource Skin.Fg}"
                                                           FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="2" Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.Border}"
                                                        BorderThickness="1" CornerRadius="4" Padding="6,1" VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <TextBlock Text="{Binding PowerText}" Foreground="{DynamicResource Skin.Accent}" FontSize="12"/>
                                                </Border>
                                            </Grid>
                                            <!-- skill badges (일반 / 스티그마) -->
                                            <StackPanel Margin="0,6,0,0" Visibility="{Binding NormalBadgesVisibility}">
                                                <TextBlock Text="일반" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10" Opacity="0.75" Margin="0,0,0,3"/>
                                                <ItemsControl ItemsSource="{Binding NormalBadges}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="1"
                                                                    CornerRadius="4" Padding="4,2" Margin="0,0,4,4">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Skin.Fg}" FontSize="11" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Margin="0,2,0,0" Visibility="{Binding StigmaBadgesVisibility}">
                                                <TextBlock Text="스티그마" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10" Opacity="0.75" Margin="0,0,0,3"/>
                                                <ItemsControl ItemsSource="{Binding StigmaBadges}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="1"
                                                                    CornerRadius="4" Padding="4,2" Margin="0,0,4,4">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Skin.Fg}" FontSize="11" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!-- 20s timer bar -->
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Height="6" CornerRadius="3" VerticalAlignment="Center"
                                                        Background="{DynamicResource Skin.StatBg}" ClipToBounds="True">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                                            <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="{Binding FillBrush}" CornerRadius="3"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding RemainingText}" Foreground="{DynamicResource Skin.MutedFg}"
                                                           FontSize="11" MinWidth="26" TextAlignment="Right" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</local:OverlayPanelWindow>
