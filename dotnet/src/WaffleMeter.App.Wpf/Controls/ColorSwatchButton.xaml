<UserControl x:Class="WaffleMeter.App.Wpf.Controls.ColorSwatchButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WaffleMeter.App.Wpf.Controls"
             x:Name="Root">
    <UserControl.Resources>
        <DrawingBrush x:Key="Checker" TileMode="Tile" Viewport="0,0,10,10" ViewportUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#2B2B2B"><GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,10,10"/></GeometryDrawing.Geometry></GeometryDrawing>
                    <GeometryDrawing Brush="#3C3C3C"><GeometryDrawing.Geometry><GeometryGroup><RectangleGeometry Rect="0,0,5,5"/><RectangleGeometry Rect="5,5,5,5"/></GeometryGroup></GeometryDrawing.Geometry></GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>
    <Grid>
        <ToggleButton x:Name="SwatchButton" Width="28" Height="28" Cursor="Hand" Padding="0" BorderThickness="0" Background="Transparent">
            <Border CornerRadius="6" Background="{StaticResource Checker}" ClipToBounds="True"
                    BorderBrush="#22FFFFFF" BorderThickness="1">
                <Border x:Name="Chip" CornerRadius="6"/>
            </Border>
        </ToggleButton>
        <Popup IsOpen="{Binding IsChecked, ElementName=SwatchButton}" StaysOpen="False"
               Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="#FF1B1B1B" CornerRadius="8" Padding="12" Margin="6" BorderBrush="#33FFFFFF" BorderThickness="1">
                <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <controls:ColorPickerControl Color="{Binding Color, ElementName=Root, Mode=TwoWay}"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>
