<UserControl x:Class="WaffleMeter.App.Wpf.Controls.GradientRowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WaffleMeter.App.Wpf.Controls"
             x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" x:Name="Preview" Height="28" CornerRadius="6" Margin="0,0,8,0"
                BorderBrush="#22FFFFFF" BorderThickness="1"/>
        <controls:ColorSwatchButton Grid.Column="1" Color="{Binding FromColor, ElementName=Root, Mode=TwoWay}" Margin="0,0,4,0"/>
        <controls:ColorSwatchButton Grid.Column="2" Color="{Binding ToColor, ElementName=Root, Mode=TwoWay}"/>
    </Grid>
</UserControl>
