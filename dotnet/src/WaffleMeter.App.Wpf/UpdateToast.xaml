<local:OverlayPanelWindow x:Class="WaffleMeter.App.Wpf.UpdateToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="업데이트"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="Height" Width="320" Left="40" Top="40" FontFamily="Segoe UI">
    <Window.Resources>
        <local:RatioToStarConverter x:Key="RatioToStar"/>
    </Window.Resources>
    <Border CornerRadius="8" BorderThickness="1" Background="{DynamicResource Skin.PanelBg}" BorderBrush="{DynamicResource Skin.Border}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="8" Opacity="0.4" Color="#000000"/>
        </Border.Effect>
        <StackPanel Margin="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6" VerticalAlignment="Top" Margin="0,0,10,0"
                        Background="{DynamicResource Skin.ControlBg}" BorderBrush="{DynamicResource Skin.ControlBorder}" BorderThickness="1">
                    <TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding IconBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Skin.Fg}" FontSize="13" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="2" Content="&#xE8BB;" Click="OnCloseButton" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Width="22" Height="22" Padding="0" VerticalAlignment="Top" Cursor="Hand"
                        Background="Transparent" Foreground="{DynamicResource Skin.MutedFg}" BorderThickness="0"/>
            </Grid>

            <!-- progress (downloading) -->
            <StackPanel Margin="0,10,0,0" Visibility="{Binding ProgressVisibility}">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="다운로드 중" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding PercentText}" Foreground="#FF2DD4BF" FontSize="10" HorizontalAlignment="Right"/>
                </Grid>
                <Border Height="6" CornerRadius="3" Background="{DynamicResource Skin.ControlBg}" ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding ProgressRatio, Converter={StaticResource RatioToStar}}"/>
                            <ColumnDefinition Width="{Binding ProgressRest, Converter={StaticResource RatioToStar}}"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#FF06B6D4" Offset="0"/>
                                    <GradientStop Color="#FF34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- restart (ready) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Visibility="{Binding RestartVisibility}">
                <Button Content="지금 재시작" Click="OnRestart" Height="28" Padding="12,0" Cursor="Hand"
                        Background="#FF0891B2" Foreground="White" BorderThickness="0" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</local:OverlayPanelWindow>
