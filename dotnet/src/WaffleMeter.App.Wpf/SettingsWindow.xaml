<Window x:Class="WaffleMeter.App.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        xmlns:controls="clr-namespace:WaffleMeter.App.Wpf.Controls"
        Title="설정" Width="760" Height="560" MinWidth="640" MinHeight="440"
        Background="{DynamicResource Skin.WindowBg}"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WaffleMeter.App.Wpf;component/Themes/Skin.Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:InverseBooleanToVisibilityConverter x:Key="BoolToVisInverse"/>
            <local:StringEqualsToVisibilityConverter x:Key="NavVis"/>
            <local:FontFamilyConverter x:Key="FontConv"/>
            <!-- HotkeyCaptureBox is a TextBox subclass, so the implicit TextBox style (Skin.Controls)
                 doesn't auto-apply; inherit it so the hotkey inputs match the other dark controls. -->
            <Style TargetType="{x:Type local:HotkeyCaptureBox}" BasedOn="{StaticResource {x:Type TextBox}}"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid TextElement.Foreground="{DynamicResource Skin.Fg}"
          TextElement.FontFamily="{Binding FontFamily, Converter={StaticResource FontConv}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- body: nav rail + content -->
        <Grid Grid.Row="0" Margin="10,14,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="148"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" Style="{StaticResource NavList}" ItemContainerStyle="{StaticResource NavItem}"
                     SelectedValuePath="Tag" SelectedValue="{Binding SelectedNav}" Margin="6,0,6,0">
                <ListBoxItem Tag="display" Content="화면"/>
                <ListBoxItem Tag="theme" Content="테마 색상"/>
                <ListBoxItem Tag="hotkeys" Content="단축키"/>
                <ListBoxItem Tag="advanced" Content="고급"/>
                <ListBoxItem Tag="stats" Content="공개 설정"/>
                <ListBoxItem Tag="diag" Content="진단"/>
            </ListBox>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="16,0,12,0">
                <Grid>
                    <!-- ===== 화면 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=display}">
                        <TextBlock Text="표시 설정" Style="{StaticResource SectionHeader}"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="표시 형식" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="DPS 카드의 정보 조합을 전환합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding DisplayModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding DisplayMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="딜량 기준" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="딜량을 DPS로 볼지 누적 피해량으로 볼지 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding DamageValueModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding DamageValueMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="기여도 표시 방식" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="파티 기여도 또는 보스 체력 기여도로 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding ContributionModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding ContributionMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="아이디 표기" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="다른 플레이어 이름의 표시 범위를 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding NameDisplays}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding NameDisplay}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="보스 표시 형식" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="타겟 바의 보스 체력 표기 방식을 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding TargetInfoDisplayModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding TargetInfoDisplayMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="게이지 형태" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="피해량 막대의 표시 형태를 선택합니다 (칸 채우기 / 얇은 바 / 없음)." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding BarStyles}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding BarStyle}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="스타일 (스킨)" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="앱 전체의 색 테마 프리셋입니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding Skins}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Name" SelectedValue="{Binding Skin}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="글꼴" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="번들 글꼴이 없으면 맑은 고딕으로 표시됩니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding FontFamilies}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding FontFamily}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{Binding RowHeight, StringFormat='행 높이 — {0}px'}" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="미터 한 줄의 높이입니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="24" Maximum="80" Value="{Binding RowHeight}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="아이온 활성화 시 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="AION2 창이 활성화된 동안에만 미터기를 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsAutoHide}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="다중 모니터 이동" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="모니터 경계를 넘어 창 위치를 보정합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding MultiMonitorMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="작업표시줄 / Alt+Tab 모드" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="오버레이를 일반 창으로 바꿔 작업표시줄·Alt+Tab에 표시합니다. (자동 숨김 해제)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding TaskbarMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="서버 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="닉네임 옆에 서버 약칭을 [ ] 안에 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowServerTag}"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="파티 신청 패널 자동 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="파티 신청이 오면 패널을 자동으로 띄웁니다. 끄면 헤더의 파티 신청 버튼으로 직접 열 수 있습니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowJoinPanel}"/>
                        </Grid>

                        <TextBlock Text="컴팩트 모드" Style="{StaticResource SectionHeader}" Margin="0,8,0,10"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="컴팩트 모드" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="타겟 바와 전투 시간 바를 숨겨 미터기를 작게 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsMinimal}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="컴팩트 모드 중 전투 시간 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="컴팩트 모드에서도 전투 시간 바를 유지합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowCombatTimerInMinimal}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="컴팩트 모드 중 보스 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="컴팩트 모드에서도 타겟(보스) 바를 유지합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowTargetInfoInMinimal}"/>
                        </Grid>

                        <TextBlock Text="업데이트" Style="{StaticResource SectionHeader}" Margin="0,8,0,10"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{Binding Version, StringFormat='현재 버전 — v{0}'}" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="최신 버전을 확인하고 백그라운드에서 내려받습니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="업데이트 확인" Click="OnCheckUpdate" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- ===== 테마 색상 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=theme}">
                        <TextBlock Text="테마 색상" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="유저 이름 색상" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="천족" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.ServerAColor, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="마족" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.ServerBColor, Mode=TwoWay}"/></Grid>

                        <TextBlock Text="미터 바 색상" Style="{StaticResource Label}" Margin="0,12,0,4"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="색상 방식" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" HorizontalAlignment="Left" Width="200" ItemsSource="{Binding BarColorModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding Theme.BarColorMode, Mode=TwoWay}"/></Grid>
                        <!-- 내 캐릭터(본인) 색은 두 모드 모두에서 사용 -->
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="내 캐릭터" VerticalAlignment="Center"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.UserBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.UserBarTo, Mode=TwoWay}"/></Grid>

                        <!-- 본인 강조: 기여도 티어 색 -->
                        <StackPanel Visibility="{Binding Theme.BarColorMode, Converter={StaticResource NavVis}, ConverterParameter=self}">
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="일반" VerticalAlignment="Center"/>
                                <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.NormalBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.NormalBarTo, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="경고 (기여도 5% 미만)" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.WarningBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.WarningBarTo, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="에러 (기여도 3% 미만)" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.ErrorBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.ErrorBarTo, Mode=TwoWay}"/></Grid>
                        </StackPanel>

                        <!-- 직업 강조: 직업별 색 (기본값 = 조인 패널과 동일 팔레트) -->
                        <StackPanel Visibility="{Binding Theme.BarColorMode, Converter={StaticResource NavVis}, ConverterParameter=job}">
                            <TextBlock Text="직업별 색상" Style="{StaticResource Label}" Margin="0,8,0,4"/>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="검성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarGladiator, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="수호성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarTemplar, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="궁성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarRanger, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="살성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarAssassin, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="마도성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarSorcerer, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="치유성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarCleric, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="정령성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarElementalist, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="호법성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarChanter, Mode=TwoWay}"/></Grid>
                        </StackPanel>

                        <TextBlock Text="미터 텍스트 색상" Style="{StaticResource Label}" Margin="0,12,0,4"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="누적 / 전투력" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatAmount, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DPS / 피해량" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatDps, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="퍼센트" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatPercent, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="전투 시간" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.CombatTimeColor, Mode=TwoWay}"/></Grid>

                        <TextBlock Text="보스 / 전투 기록" Style="{StaticResource Label}" Margin="0,12,0,4"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="타겟 / 전투 기록" VerticalAlignment="Center"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.BossBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.BossBarTo, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="남은 체력 / 경과 시간" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.BossRightValue, Mode=TwoWay}"/></Grid>

                        <Button Content="테마 색상 초기화" HorizontalAlignment="Left" Margin="0,14,0,0" Click="OnResetTheme"/>
                    </StackPanel>

                    <!-- ===== 단축키 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=hotkeys}">
                        <TextBlock Text="단축키" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="단일 키 또는 Ctrl/Alt 조합으로 지정할 수 있습니다." Style="{StaticResource SettingDesc}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="전투 초기화" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <local:HotkeyCaptureBox Grid.Column="1" Combo="{Binding PendingReset, Mode=TwoWay}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="표시 / 숨김" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <local:HotkeyCaptureBox Grid.Column="1" Combo="{Binding PendingVisibility, Mode=TwoWay}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="클릭 통과 / 잠금" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <local:HotkeyCaptureBox Grid.Column="1" Combo="{Binding PendingClickThrough, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ===== 고급 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=advanced}">
                        <TextBlock Text="창 동작" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="닫기 버튼 동작" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="X 버튼을 눌렀을 때 트레이로 보낼지 종료할지 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding CloseActions}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding CloseAction}"/>
                        </Grid>

                        <TextBlock Text="캡처 방식" Style="{StaticResource SectionHeader}" Margin="0,6,0,10"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="패킷 캡처 백엔드" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="WinDivert가 막히면 Npcap으로 전환할 수 있습니다. (재시작 후 적용)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding CaptureBackends}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding CaptureBackend}"/>
                        </Grid>
                        <!-- 서버 IP/포트는 자동 감지되며 사용자가 직접 설정할 일이 없어 UI에서 숨김
                             (값/저장 경로는 SettingsViewModel.ServerIp/Port/SaveServer에 그대로 보존). -->
                    </StackPanel>

                    <!-- ===== 공개 설정 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=stats}">
                        <TextBlock Text="공개 설정 (익명 통계)" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="익명 통계 업로드에 동의" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="캐릭터별로 동의가 기억됩니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ConsentAccepted}" IsEnabled="{Binding CharacterDetected}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="업로드 활성화" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding UploadEnabled}" IsEnabled="{Binding CharacterDetected}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="캐릭터 공개" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding PublicCharacter}" IsEnabled="{Binding CharacterDetected}"/>
                        </Grid>
                        <TextBlock Text="캐릭터 접속 후 동의할 수 있어요" Foreground="#FFCC8800" FontSize="11"
                                   Visibility="{Binding CharacterDetected, Converter={StaticResource BoolToVisInverse}, FallbackValue=Collapsed}"/>
                        <TextBlock Text="{Binding ConsentStatus}" Style="{StaticResource SettingDesc}" Margin="0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="적용" Click="OnApplyConsent" Margin="0,0,8,0"/>
                            <Button Content="서버 동기화" Click="OnRefreshConsent"/>
                        </StackPanel>
                        <TextBlock Text="{Binding UploadStatus}" Style="{StaticResource SettingDesc}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- ===== 진단 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=diag}">
                        <TextBlock Text="진단 — 패킷 로깅" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="전투를 기록해 재생 가능한 코퍼스(packet-debug-logs)를 남깁니다. 진단/검증용이며, 켜두면 디스크에 계속 기록됩니다."
                                   Style="{StaticResource SettingDesc}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Button Content="{Binding LoggingButtonLabel}" Width="110" Click="OnToggleLogging" Margin="0,0,8,0"/>
                            <Button Content="로그 폴더 열기" Click="OnOpenLogFolder"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LoggingStatus}" Style="{StaticResource SettingDesc}" Margin="0,6,0,0"/>

                        <TextBlock Text="위치 초기화" Style="{StaticResource SectionHeader}" Margin="0,16,0,8"/>
                        <TextBlock Text="드래그로 옮긴 창들을 기본 위치로 되돌립니다." Style="{StaticResource SettingDesc}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="미터기 위치" Click="OnResetMeterPosition" Margin="0,0,8,0"/>
                            <Button Content="파티 신청 위치" Click="OnResetJoinPosition" Margin="0,0,8,0"/>
                            <Button Content="전투 기록 위치" Click="OnResetHistoryPosition"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- footer -->
        <Grid Grid.Row="1" Margin="20,10,16,14">
            <TextBlock Text="{Binding Version, StringFormat='waffle_meter v{0}'}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="기본값 복원" Click="OnResetDefaults" Margin="0,0,8,0"/>
                <Button Content="취소" Width="80" Click="OnCancel" Margin="0,0,8,0"/>
                <Button Content="저장" Width="80" Click="OnSave"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
