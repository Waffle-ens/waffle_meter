<Window x:Class="WaffleMeter.App.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        xmlns:controls="clr-namespace:WaffleMeter.App.Wpf.Controls"
        Title="waffle_meter 설정"
        Width="460" SizeToContent="Height" Background="#FF1E1E1E"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" FontFamily="Segoe UI">
    <Window.Resources>
        <local:InverseBooleanToVisibilityConverter x:Key="BoolToVisInverse"/>
        <local:FontFamilyConverter x:Key="FontConv"/>

        <!-- Dark theme: the overlay/detail windows are dark, so the settings window matches. -->
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#FFE0E0E0"/></Style>
        <Style TargetType="TextBlock" x:Key="Label"><Setter Property="FontSize" Value="11"/><Setter Property="Foreground" Value="#FF9A9A9A"/></Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFEEEEEE"/>
            <Setter Property="BorderBrush" Value="#FF454545"/>
            <Setter Property="CaretBrush" Value="#FFEEEEEE"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="Background" Value="#FF383838"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#FF484848"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="b" Property="Background" Value="#FF2C2C2C"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFEEEEEE"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="b" Property="Background" Value="#FF3A6EA5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,2,0,8"/>
            <Setter Property="Foreground" Value="#FFEEEEEE"/>
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="#FF454545" BorderThickness="1" CornerRadius="4">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                                                  Fill="#FFAAAAAA" Data="M 0 0 L 8 0 L 4 4 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,24,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                <Border Background="#FF2A2A2A" BorderBrush="#FF454545" BorderThickness="1" CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260"><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FFBBBBBB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="b" Background="Transparent" Padding="12,6" Margin="0,0,2,0" CornerRadius="4,4,0,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF2D2D2D"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel Margin="14" TextElement.FontFamily="{Binding FontFamily, Converter={StaticResource FontConv}}">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Width="80" Click="OnCancel" Margin="0,0,8,0"/>
            <Button Content="저장" Width="80" Click="OnSave"/>
        </StackPanel>
        <TabControl>
            <TabItem Header="표시">
                <StackPanel Margin="10">
                    <TextBlock Text="표시 형식" Style="{StaticResource Label}"/>
                    <ComboBox ItemsSource="{Binding DisplayModes}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding DisplayMode}"/>
                    <TextBlock Text="딜량 기준" Style="{StaticResource Label}"/>
                    <ComboBox ItemsSource="{Binding DamageValueModes}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding DamageValueMode}"/>
                    <TextBlock Text="기여도 표시 방식" Style="{StaticResource Label}"/>
                    <ComboBox ItemsSource="{Binding ContributionModes}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding ContributionMode}"/>
                    <TextBlock Text="아이디 표기" Style="{StaticResource Label}"/>
                    <ComboBox ItemsSource="{Binding NameDisplays}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding NameDisplay}"/>
                    <TextBlock Text="글꼴" Style="{StaticResource Label}"/>
                    <ComboBox ItemsSource="{Binding FontFamilies}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding FontFamily}"/>
                    <TextBlock Text="{Binding RowHeight, StringFormat='행 높이 — {0}px'}" Style="{StaticResource Label}" Margin="0,4,0,0"/>
                    <Slider Minimum="24" Maximum="80" Value="{Binding RowHeight}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="오버레이">
                <StackPanel Margin="10">
                    <CheckBox Content="자동 숨김 (아이온2 포커싱 아닐 때 숨김)" IsChecked="{Binding IsAutoHide}" Margin="0,4"/>
                    <CheckBox Content="다중 모니터 이동" IsChecked="{Binding MultiMonitorMode}" Margin="0,4"/>
                    <TextBlock Text="{Binding MeterOpacity, StringFormat='미터 투명도 — {0:P0}'}" Style="{StaticResource Label}" Margin="0,6,0,0"/>
                    <Slider Minimum="0" Maximum="1" Value="{Binding MeterOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True"/>

                    <Separator Margin="0,10"/>
                    <TextBlock Text="단축키 (Ctrl/Alt 필요)" Style="{StaticResource Label}"/>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="전투 초기화" VerticalAlignment="Center"/>
                        <local:HotkeyCaptureBox Grid.Column="1" Combo="{Binding PendingReset, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="표시/숨김" VerticalAlignment="Center"/>
                        <local:HotkeyCaptureBox Grid.Column="1" Combo="{Binding PendingVisibility, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="클릭 통과" VerticalAlignment="Center"/>
                        <local:HotkeyCaptureBox Grid.Column="1" Combo="{Binding PendingClickThrough, Mode=TwoWay}"/>
                    </Grid>

                    <Separator Margin="0,10"/>
                    <TextBlock Text="서버 IP (CIDR)" Style="{StaticResource Label}"/>
                    <TextBox Text="{Binding ServerIp}" Margin="0,2,0,6"/>
                    <TextBlock Text="포트" Style="{StaticResource Label}"/>
                    <TextBox Text="{Binding ServerPort}" Margin="0,2,0,6"/>
                    <Button Content="서버 저장" Width="90" HorizontalAlignment="Left" Click="OnSaveServer"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="테마">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="440">
                    <StackPanel Margin="10">
                        <TextBlock Text="유저 이름 색상" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="천족" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.ServerAColor, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="마족" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.ServerBColor, Mode=TwoWay}"/></Grid>

                        <TextBlock Text="미터 바 색상" Style="{StaticResource Label}" Margin="0,10,0,2"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="내 캐릭터" VerticalAlignment="Center"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.UserBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.UserBarTo, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="일반" VerticalAlignment="Center"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.NormalBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.NormalBarTo, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="경고 (기여도 5% 미만)" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.WarningBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.WarningBarTo, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="에러 (기여도 3% 미만)" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.ErrorBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.ErrorBarTo, Mode=TwoWay}"/></Grid>

                        <TextBlock Text="미터 텍스트 색상" Style="{StaticResource Label}" Margin="0,10,0,2"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="누적 / 전투력" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatAmount, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DPS / 피해량" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatDps, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="퍼센트" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatPercent, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="전투 시간" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.CombatTimeColor, Mode=TwoWay}"/></Grid>

                        <TextBlock Text="보스 / 전투 기록" Style="{StaticResource Label}" Margin="0,10,0,2"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="타겟 / 전투 기록" VerticalAlignment="Center"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.BossBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.BossBarTo, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="남은 체력 / 경과 시간" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.BossRightValue, Mode=TwoWay}"/></Grid>

                        <Button Content="테마 초기화" Width="100" HorizontalAlignment="Left" Margin="0,12,0,0" Click="OnResetTheme"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="통계">
                <StackPanel Margin="10">
                    <CheckBox Content="익명 통계 업로드에 동의" IsChecked="{Binding ConsentAccepted}" IsEnabled="{Binding CharacterDetected}" Margin="0,4"/>
                    <CheckBox Content="업로드 활성화" IsChecked="{Binding UploadEnabled}" IsEnabled="{Binding CharacterDetected}" Margin="16,2,0,2"/>
                    <CheckBox Content="캐릭터 공개" IsChecked="{Binding PublicCharacter}" IsEnabled="{Binding CharacterDetected}" Margin="16,2,0,2"/>
                    <TextBlock Text="캐릭터 접속 후 동의할 수 있어요" Foreground="#FFCC8800" FontSize="11"
                               Visibility="{Binding CharacterDetected, Converter={StaticResource BoolToVisInverse}, FallbackValue=Collapsed}"/>
                    <TextBlock Text="{Binding ConsentStatus}" Foreground="#FF666666" FontSize="11" Margin="0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button Content="적용" Width="80" Click="OnApplyConsent" Margin="0,0,8,0"/>
                        <Button Content="서버 동기화" Width="100" Click="OnRefreshConsent"/>
                    </StackPanel>
                    <TextBlock Text="{Binding UploadStatus}" Foreground="#FF666666" FontSize="11" Margin="0,2"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="진단">
                <StackPanel Margin="10">
                    <TextBlock Text="패킷 로깅" Style="{StaticResource Label}"/>
                    <TextBlock Text="전투를 기록해 재생 가능한 코퍼스(packet-debug-logs)를 남깁니다. 진단/검증용이며, 켜두면 디스크에 계속 기록됩니다."
                               TextWrapping="Wrap" Foreground="#FF888888" FontSize="11" Margin="0,2,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button Content="{Binding LoggingButtonLabel}" Width="100" Click="OnToggleLogging" Margin="0,0,8,0"/>
                        <Button Content="로그 폴더 열기" Width="110" Click="OnOpenLogFolder"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LoggingStatus}" Foreground="#FF666666" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
