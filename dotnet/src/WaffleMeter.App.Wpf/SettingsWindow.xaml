<Window x:Class="WaffleMeter.App.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        xmlns:controls="clr-namespace:WaffleMeter.App.Wpf.Controls"
        Title="설정" Width="760" Height="560" MinWidth="640" MinHeight="440"
        Background="{DynamicResource Skin.WindowBg}"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WaffleMeter.App.Wpf;component/Themes/Skin.Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:InverseBooleanToVisibilityConverter x:Key="BoolToVisInverse"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <local:StringEqualsToVisibilityConverter x:Key="NavVis"/>
            <local:FontFamilyConverter x:Key="FontConv"/>
            <!-- day-of-week toggle chip for custom alarms: matches the meter chip aesthetic (dim when off,
                 subtle accent fill + accent border/text when on), instead of the default square CheckBox. -->
            <Style x:Key="DayChip" TargetType="ToggleButton">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="Margin" Value="0,0,5,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="b" CornerRadius="6" BorderThickness="1" Opacity="0.5"
                                    Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.SoftBorder}">
                                <TextBlock x:Name="t" Text="{TemplateBinding Content}" Foreground="{DynamicResource Skin.Fg}"
                                           FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="b" Property="Opacity" Value="1.0"/>
                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource Skin.AccentSoft}"/>
                                    <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Skin.Accent}"/>
                                    <Setter TargetName="t" Property="Foreground" Value="{DynamicResource Skin.Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Buff-preset slot chip: DayChip's look, sized to hold a slot name. No GroupName — the preset
                 bar is rendered on two tabs at once and WPF groups by name across the whole window, which
                 would make the two bars fight. The view-model clears the other chips instead. -->
            <Style x:Key="PresetChip" TargetType="RadioButton">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="MinWidth" Value="92"/>
                <Setter Property="MaxWidth" Value="150"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="b" CornerRadius="6" BorderThickness="1" Opacity="0.5" Padding="10,0"
                                    Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.SoftBorder}">
                                <TextBlock x:Name="t" Text="{TemplateBinding Content}" Foreground="{DynamicResource Skin.Fg}"
                                           FontSize="12" TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="b" Property="Opacity" Value="1.0"/>
                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource Skin.AccentSoft}"/>
                                    <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Skin.Accent}"/>
                                    <Setter TargetName="t" Property="Foreground" Value="{DynamicResource Skin.Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- The preset bar, shown on both buff tabs (a preset spans them), so it lives here once. -->
            <DataTemplate x:Key="BuffPresetBar">
                <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                        Background="{DynamicResource Skin.RowBg}" BorderThickness="1"
                        BorderBrush="{DynamicResource Skin.SoftBorder}">
                    <StackPanel>
                        <TextBlock Text="버프 오버레이 프리셋" Style="{StaticResource SettingTitle}"/>
                        <TextBlock Text="버프 오버레이 설정을 슬롯 3개에 저장합니다. 슬롯을 고르면 바로 적용되고, 이후 바꾼 설정은 그 슬롯에 자동 저장됩니다. (오버레이 켬/끔은 프리셋과 무관)"
                                   Style="{StaticResource SettingDesc}" Margin="0,0,0,9"/>
                        <ItemsControl ItemsSource="{Binding PresetSlots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource PresetChip}" Content="{Binding Name}"
                                                 IsChecked="{Binding IsActive, Mode=TwoWay}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="이름" VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontSize="12" Foreground="{DynamicResource Skin.MutedFg}"/>
                            <TextBox Grid.Column="1" Height="30" Padding="8,4" MaxLength="20"
                                     VerticalContentAlignment="Center" KeyDown="OnPresetNameKeyDown"
                                     Text="{Binding ActivePresetName, UpdateSourceTrigger=LostFocus}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </DataTemplate>
            <!-- HotkeyCaptureBox is a TextBox subclass, so the implicit TextBox style (Skin.Controls)
                 doesn't auto-apply; inherit it so the hotkey inputs match the other dark controls. -->
            <Style TargetType="{x:Type local:HotkeyCaptureBox}" BasedOn="{StaticResource {x:Type TextBox}}"/>
            <!-- 단축키 미지정(지우기) 버튼. The X is drawn as a vector Path, NOT a glyph: the bound theme
                 font (e.g. NEXON Lv2 Gothic) lacks U+2715/✕, so a text "✕" renders as a tofu/fallback. -->
            <Style x:Key="HotkeyClearButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Margin" Value="6,0,0,0"/>
                <Setter Property="ToolTip" Value="미지정 (단축키 사용 안 함)"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" CornerRadius="5">
                                <Path HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="10" Stretch="None"
                                      Stroke="{DynamicResource Skin.Fg}" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M0,0 L10,10 M10,0 L0,10"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource Skin.ControlHover}"/></Trigger>
                                <Trigger Property="IsPressed" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource Skin.ControlBg}"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Reusable hover-help "?" dot (same visual as the 단축키 help marker). Put a Border with
                 this style next to a control and give it a Border.ToolTip for the explanation. -->
            <Style x:Key="HelpDot" TargetType="Border">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="CornerRadius" Value="9"/>
                <Setter Property="Cursor" Value="Help"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Background" Value="{DynamicResource Skin.AccentSoft}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Skin.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="150"/>
                <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
            </Style>
            <Style x:Key="HelpQ" TargetType="TextBlock">
                <Setter Property="Text" Value="?"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{DynamicResource Skin.Accent}"/>
            </Style>

            <!-- 브랜드 색을 그대로 채우는 링크 버튼(Discord 등). 기본 버튼 크롬을 쓰면 스킨의 회색 테두리가
                 얹혀 브랜드 색이 죽는다. -->
            <Style x:Key="BrandButton" TargetType="Button">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="7">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Opacity" Value="0.86"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="b" Property="Opacity" Value="0.72"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 좌측 탭 줄 맨 아래에 붙는 '탭처럼 보이는' 링크 버튼. NavItem(ListBoxItem) 템플릿을 Button으로
                 옮겨 온 것 — 탭 목록의 항목이 아니라 바깥으로 나가는 링크라 ListBoxItem으로 만들면 선택
                 상태가 생겨 "지금 이 탭을 보고 있다"는 거짓 신호를 준다. -->
            <Style x:Key="NavLinkButton" TargetType="Button">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="12,9" Margin="0,1">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource Skin.ControlHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid TextElement.Foreground="{DynamicResource Skin.Fg}"
          TextElement.FontFamily="{Binding FontFamily, Converter={StaticResource FontConv}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- body: nav rail + content -->
        <Grid Grid.Row="0" Margin="10,14,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="148"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListBox Grid.Row="0" Style="{StaticResource NavList}" ItemContainerStyle="{StaticResource NavItem}"
                     SelectedValuePath="Tag" SelectedValue="{Binding SelectedNav}" Margin="6,0,6,0"
                     SelectionChanged="OnNavChanged">
                <ListBox.Resources>
                    <!-- 2-line nav item: title + a dim one-line summary of what the section holds -->
                    <Style x:Key="NavTitle" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
                    </Style>
                    <Style x:Key="NavSub" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="10.5"/>
                        <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
                        <Setter Property="Margin" Value="0,1,0,0"/>
                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                    </Style>
                </ListBox.Resources>
                <ListBoxItem Tag="display">
                    <StackPanel><TextBlock Text="화면" Style="{StaticResource NavTitle}"/><TextBlock Text="표시 형식 · 최적화 · 오드" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="combat">
                    <StackPanel><TextBlock Text="전투 보조" Style="{StaticResource NavTitle}"/><TextBlock Text="버프 오버레이" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="buffalerts">
                    <StackPanel><TextBlock Text="버프 알림" Style="{StaticResource NavTitle}"/><TextBlock Text="직업별 버프 표시·음성" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="alarms">
                    <StackPanel><TextBlock Text="알림" Style="{StaticResource NavTitle}"/><TextBlock Text="슈고 페스타 · 사용자 알람" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="theme">
                    <StackPanel><TextBlock Text="테마 색상" Style="{StaticResource NavTitle}"/><TextBlock Text="스킨 · 색상 프리셋" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="hotkeys">
                    <StackPanel><TextBlock Text="단축키" Style="{StaticResource NavTitle}"/><TextBlock Text="초기화 · 표시 · 클릭 통과" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="advanced">
                    <StackPanel><TextBlock Text="고급" Style="{StaticResource NavTitle}"/><TextBlock Text="캡처 방식 · 렌더링 호환" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="replay">
                    <StackPanel><TextBlock Text="리플레이 (베타)" Style="{StaticResource NavTitle}"/><TextBlock Text="전투 이동 기록 · 저장 경로" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="dummy">
                    <StackPanel><TextBlock Text="허수아비" Style="{StaticResource NavTitle}"/><TextBlock Text="허수 테스트 · 시간 제한" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="stats">
                    <StackPanel><TextBlock Text="캐릭터 관리" Style="{StaticResource NavTitle}"/><TextBlock Text="오드 · 공개 · 익명 통계" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="diag">
                    <StackPanel><TextBlock Text="진단" Style="{StaticResource NavTitle}"/><TextBlock Text="로그 · 문제 해결" Style="{StaticResource NavSub}"/></StackPanel>
                </ListBoxItem>
            </ListBox>

            <!-- 탭 줄 맨 아래의 '와터기' — 탭처럼 보이지만 눌리면 통계 웹서비스를 브라우저로 연다.
                 위 목록과 구분되도록 얇은 구분선을 두고, 바깥으로 나간다는 표시를 오른쪽에 붙였다. -->
            <Button Grid.Row="1" Style="{StaticResource NavLinkButton}" Margin="6,6,6,2" Click="OnOpenStatsWeb"
                    ToolTip="전투 기록과 통계를 볼 수 있는 웹서비스를 브라우저로 엽니다.">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="와터기" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Skin.Fg}"/>
                        <TextBlock Text="전투 기록 통계 웹" FontSize="10.5" Margin="0,1,0,0"
                                   Foreground="{DynamicResource Skin.MutedFg}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource Skin.MutedFg}"/>
                </Grid>
            </Button>
            </Grid>

            <ScrollViewer x:Name="ContentScroll" Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="16,0,12,0">
                <Grid>
                    <!-- ===== 알림 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=alarms}">
                        <TextBlock Text="슈고 페스타 알림" Style="{StaticResource SectionHeader}"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="슈고 페스타 알림" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="매시 정각 이벤트 전에 알림 토스트를 띄웁니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShugoAlarmEnabled}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="10분 전 알림" Style="{StaticResource SettingTitle}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShugoLead10}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="5분 전 알림" Style="{StaticResource SettingTitle}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShugoLead5}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="1분 전 알림" Style="{StaticResource SettingTitle}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShugoLead1}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="시작 알림" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="이벤트가 시작되는 정각에 알립니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShugoLeadStart}"/>
                        </Grid>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="소리" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="알림 소리" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="알림이 뜰 때 짧은 효과음을 재생합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AlarmSoundEnabled}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="알림 음량" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="알림 효과음의 크기입니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="0" Maximum="1" Value="{Binding AlarmVolume}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="음성 알림 (한국어)" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="알림 내용을 한국어 음성으로 읽어줍니다. 인터넷이 필요하며, 실패하면 효과음으로 대체됩니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding TtsEnabled}"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                            <Button Content="소리 테스트" Click="OnTestAlarmSound" HorizontalAlignment="Left"
                                    Height="30" Padding="14,0" Cursor="Hand" Margin="0,0,8,0"/>
                            <Button Content="음성 테스트" Click="OnTestTts" HorizontalAlignment="Left"
                                    Height="30" Padding="14,0" Cursor="Hand"/>
                        </StackPanel>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="필드보스 리젠 알림" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="필드보스 알림" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="필드보스 리젠 시각이 감지되면 리젠 전에 알려줍니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding FieldBossAlarmEnabled}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="알림 받을 보스 선택" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="원하는 필드보스만 알림을 받도록 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="보스 선택" MinWidth="92" Click="OnOpenFieldBossPicker" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="미리 알림" Style="{StaticResource SettingTitle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <CheckBox Content="5분 전" IsChecked="{Binding FieldBossLead5}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <CheckBox Content="10분 전" IsChecked="{Binding FieldBossLead10}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <CheckBox Content="30분 전" IsChecked="{Binding FieldBossLead30}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="전투 중 알림 숨김" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="미터에 전투가 기록되는 동안에는 필드보스 알림을 띄우지 않습니다. (전투 종료 후 시간이 남아있으면 표시)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding FieldBossAlarmMuteInCombat}"/>
                        </Grid>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="커스텀 알람" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                        <!-- add form -->
                        <Border Background="{DynamicResource Skin.ControlBg}" BorderBrush="{DynamicResource Skin.ControlBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewAlarmTitle, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32" Padding="8,4" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Grid.Column="1" Width="60" Height="32" ItemsSource="{Binding Hours}" SelectedItem="{Binding NewAlarmHour}" Margin="0,0,4,0"/>
                                    <ComboBox Grid.Column="2" Width="60" Height="32" ItemsSource="{Binding Minutes}" SelectedItem="{Binding NewAlarmMinute}"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ToggleButton Content="일" Style="{StaticResource DayChip}" IsChecked="{Binding DaySun}"/>
                                    <ToggleButton Content="월" Style="{StaticResource DayChip}" IsChecked="{Binding DayMon}"/>
                                    <ToggleButton Content="화" Style="{StaticResource DayChip}" IsChecked="{Binding DayTue}"/>
                                    <ToggleButton Content="수" Style="{StaticResource DayChip}" IsChecked="{Binding DayWed}"/>
                                    <ToggleButton Content="목" Style="{StaticResource DayChip}" IsChecked="{Binding DayThu}"/>
                                    <ToggleButton Content="금" Style="{StaticResource DayChip}" IsChecked="{Binding DayFri}"/>
                                    <ToggleButton Content="토" Style="{StaticResource DayChip}" IsChecked="{Binding DaySat}"/>
                                </StackPanel>
                                <Grid>
                                    <TextBlock Text="요일 미선택 시 매일 알림" Style="{StaticResource SettingDesc}" VerticalAlignment="Center"/>
                                    <Button Content="추가" Click="OnAddCustomAlarm" HorizontalAlignment="Right" Height="28" Padding="16,0" Cursor="Hand"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- list -->
                        <TextBlock Text="등록된 알람이 없습니다." Style="{StaticResource SettingDesc}" Margin="2,0,0,4"
                                   Visibility="{Binding HasCustomAlarms, Converter={StaticResource BoolToVisInverse}}"/>
                        <ItemsControl ItemsSource="{Binding CustomAlarmRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Skin.ControlBg}" BorderBrush="{DynamicResource Skin.ControlBorder}"
                                            BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TimeText}" Foreground="{DynamicResource Skin.Fg}"
                                                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Skin.Fg}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DaysText}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Enabled, Mode=OneWay}"
                                                      Click="OnToggleCustomAlarm" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <Button Grid.Column="3" Content="삭제" Click="OnDeleteCustomAlarm" Height="26" Padding="10,0" Cursor="Hand" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ===== 화면 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=display}">
                        <TextBlock Text="표시 설정" Style="{StaticResource SectionHeader}"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="표시 형식" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="DPS 카드의 정보 조합을 전환합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding DisplayModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding DisplayMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="딜량 기준" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="딜량을 DPS로 볼지 누적 피해량으로 볼지 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding DamageValueModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding DamageValueMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="기여도 표시 방식" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="파티 기여도 또는 보스 체력 기여도로 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding ContributionModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding ContributionMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="아이디 표기" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="다른 플레이어 이름의 표시 범위를 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding NameDisplays}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding NameDisplay}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="보스 표시 형식" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="타겟 바의 보스 체력 표기 방식을 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding TargetInfoDisplayModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding TargetInfoDisplayMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="게이지 형태" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="피해량·보스 체력 막대의 표시 형태를 선택합니다 (칸 채우기 / 얇은 바 / 없음)." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding BarStyles}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding BarStyle}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="스타일 (스킨)" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="앱 전체의 색 테마 프리셋입니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding Skins}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Name" SelectedValue="{Binding Skin}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="글꼴" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="번들 글꼴이 없으면 맑은 고딕으로 표시됩니다. 커스텀 폰트(.ttf/.otf)를 추가해 쓸 수 있습니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <ComboBox Width="190" ItemsSource="{Binding FontFamilies}"
                                          ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding FontFamily}"/>
                                <Button Content="커스텀 폰트 추가…" Margin="0,6,0,0" HorizontalAlignment="Right" Click="OnAddCustomFont"
                                        ToolTip="ttf/otf 파일을 선택해 목록에 추가하고 바로 적용합니다"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{Binding RowHeight, StringFormat='행 높이 — {0}px'}" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="미터 한 줄의 높이입니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="24" Maximum="80" Value="{Binding RowHeight}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        </Grid>

                        <!-- 표시 최적화: 저사양/프레임 드랍 완화 -->
                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="표시 최적화" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{Binding MaxVisibleRows, StringFormat='표시 인원 — {0}명'}" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="딜 순위 상위 인원만 표시합니다 (본인은 순위와 무관하게 항상 표시). 전체 집계는 그대로 유지됩니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="1" Maximum="10" Value="{Binding MaxVisibleRows}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{Binding RefreshIntervalMs, StringFormat='갱신 주기 — {0}ms'}" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="값이 클수록 숫자 반영은 느려지지만 전투 중 CPU·화면 부담이 줄어듭니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="100" Maximum="1000" Value="{Binding RefreshIntervalMs}"
                                    TickFrequency="100" IsSnapToTickEnabled="True" IsEnabled="{Binding RefreshSliderEnabled}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="저사양 모드" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="켜면 갱신 주기를 500ms로 고정해 게임 프레임을 우선합니다. 딜 집계 방식은 그대로 유지됩니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LowSpecMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="오드 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="인식된 캐릭터 옆에 오드 잔량을 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowAetherStatus}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="서버 응답속도 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="인식된 캐릭터 옆에 게임 서버까지의 응답속도(ms)를 표시합니다. VPN/부스터 사용 시 로컬 홉으로 표시될 수 있습니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowLatencyIndicator}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="아이온 활성화 시 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="AION2 창이 활성화된 동안에만 미터기를 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsAutoHide}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="다중 모니터 이동" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="모니터 경계를 넘어 창 위치를 보정합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding MultiMonitorMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="작업표시줄 / Alt+Tab 모드" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="오버레이를 일반 창으로 바꿔 작업표시줄·Alt+Tab에 표시합니다. (자동 숨김 해제)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding TaskbarMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="서버 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="닉네임 옆에 서버 약칭을 [ ] 안에 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowServerTag}"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="파티 신청 패널 자동 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="파티 신청이 오면 패널을 자동으로 띄웁니다. 끄면 헤더의 파티 신청 버튼으로 직접 열 수 있습니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowJoinPanel}"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="전투 전 파티원 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="던전 입장 시 전투가 시작되기 전에도 파티원을 미리 표시합니다. 첫 피해가 들어오면 자동으로 전투 화면으로 전환됩니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowPreCombatRoster}"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="던전 강제 집계 (본인/파티 미인식 시)" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="던전(원정/초월/성역) 보스 전투 중간에 미터를 켜서 캐릭터 인식이 안 될 때도, 주요 딜러를 '파티원'으로 표시해 집계를 보여줍니다. 추정 신원이라 켜는 동안 웹 통계 전송은 중단됩니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ForceInstanceTracking}"/>
                        </Grid>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="컴팩트 모드" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="컴팩트 모드" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="타겟 바와 전투 시간 바를 숨겨 미터기를 작게 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsMinimal}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="컴팩트 모드 중 전투 시간 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="컴팩트 모드에서도 전투 시간 바를 유지합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowCombatTimerInMinimal}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="컴팩트 모드 중 보스 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="컴팩트 모드에서도 타겟(보스) 바를 유지합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowTargetInfoInMinimal}"/>
                        </Grid>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="업데이트" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{Binding Version, StringFormat='현재 버전 — v{0}'}" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="최신 버전을 확인하고 백그라운드에서 내려받습니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="업데이트 확인" Click="OnCheckUpdate" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- ===== 전투 보조 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=combat}">
                        <TextBlock Text="전투 보조 UI" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="내 캐릭터에게 적용된 버프와 남은 시간을 별도 창에 표시합니다." Style="{StaticResource SettingDesc}" Margin="0,0,0,10"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource BuffPresetBar}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="버프 오버레이 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="전투 보조 창을 켭니다. 창은 드래그로 옮길 수 있습니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowBuffUi}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="미터를 숨겨도 오버레이 유지" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="미터기 본체를 숨겨도(Ctrl+H·트레이) 버프 오버레이는 계속 표시합니다. 게임이 활성일 때만 뜹니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding KeepOverlayWhenMeterHidden}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="투명 배경" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="켜면 아이콘만 떠서 배경이 투명합니다. 끄면 배경/테두리가 보여 버프가 없을 때도 창 위치를 찾아 옮길 수 있습니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding BuffUiTransparent}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="아이콘 크기" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="버프 오버레이 아이콘 크기를 고릅니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="132" VerticalAlignment="Center" SelectedIndex="{Binding BuffIconSizeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="작게 (34px)"/>
                                <ComboBoxItem Content="크게 (40px)"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="지속시간 글씨 색상" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="남은 시간 글씨 색상을 바꿉니다. (투명 배경에서 흰색이 잘 안 보일 때 유용)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding BuffTextColor, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="다른 캐릭터가 준 버프 표시" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="끄면 본인이 직접 받은 버프만 표시합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowOtherPlayerBuffs}"/>
                        </Grid>
                        <TextBlock Text="직업별 버프 표시·음성 설정은 왼쪽 '버프 알림' 탭에 있습니다." Style="{StaticResource SettingDesc}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- ===== 버프 알림 (직업별 표시/음성) ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=buffalerts}">
                        <TextBlock Text="버프 알림" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="직업별로 각 버프를 오버레이/음성 중 어떻게 알릴지 고릅니다. (소비 아이템·물약은 제외)" Style="{StaticResource SettingDesc}" Margin="0,0,0,10"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource BuffPresetBar}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="버프 시작 음성" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="'오버레이+음성' 버프가 켜지면 '스킬명 온'을 읽어줍니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding BuffTtsOnStart}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="버프 종료 음성" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="'오버레이+음성' 버프가 끝나기 직전 '스킬명 오프'를 읽어줍니다. (음성 지연 고려해 살짝 먼저)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding BuffTtsOnEnd}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="쿨타임 중 아이콘 회색" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="버프를 거는 스킬이 쿨타임이면 오버레이 아이콘을 회색으로 흐리게 표시합니다. (재사용 가능 시점 확인용)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding BuffUiGrayOnCooldown}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="표시 순서" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="오버레이에 버프를 늘어놓는 기준입니다. '적용 순서'는 버프가 유지되는 동안 자리가 바뀌지 않아 가장 안정적이고, '남은 시간 순'은 타이머가 흐를 때마다 아이콘이 움직입니다. 아래 목록에서 '위치 고정'을 켠 버프는 이 기준과 무관하게 항상 버프 오버레이의 가장 앞쪽에 표시됩니다."
                                           Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="140" VerticalAlignment="Center" SelectedIndex="{Binding BuffUiSortModeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="적용 순서"/>
                                <ComboBoxItem Content="남은 시간 순"/>
                                <ComboBoxItem Content="이름 순"/>
                            </ComboBox>
                        </Grid>

                        <TextBlock Text="아직 표시된 버프가 없습니다. 전투를 진행하면 여기에 버프가 나타납니다."
                                   Foreground="{DynamicResource Skin.MutedFg}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Visibility="{Binding BuffPicker.IsEmpty, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding BuffPicker.Groups}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Skin.SoftBorder}" Padding="0,8,0,10" Margin="0,0,0,4">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Job}" FontWeight="Bold" FontSize="13"
                                                           Foreground="{DynamicResource Skin.Accent}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Content="전체 끔" Padding="8,2" FontSize="11" Margin="0,0,4,0"
                                                            DataContext="{Binding}" Tag="g|0" Click="OnBuffGroupMode"/>
                                                    <Button Content="전체 오버레이" Padding="8,2" FontSize="11" Margin="0,0,4,0"
                                                            DataContext="{Binding}" Tag="g|1" Click="OnBuffGroupMode"/>
                                                    <Button Content="전체 음성" Padding="8,2" FontSize="11" Margin="0,0,4,0"
                                                            DataContext="{Binding}" Tag="g|2" Click="OnBuffGroupMode"/>
                                                    <Button Content="전체 음성만" Padding="8,2" FontSize="11"
                                                            DataContext="{Binding}" Tag="g|3" Click="OnBuffGroupMode"/>
                                                </StackPanel>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="2,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="26" Height="26" CornerRadius="5" Margin="0,0,9,0"
                                                                    Background="{DynamicResource Skin.RowBg}">
                                                                <Image Source="{Binding IconSource}" Width="24" Height="24"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource Skin.Fg}" FontSize="12"/>
                                                            <!-- 맨 앞 고정 토글. 글리프만으로는 켜짐/꺼짐이 구분되지 않아(사용자 제보)
                                                                 라벨 + 켜짐 상태 강조(액센트 배경/테두리)를 함께 준다. 고정된 것끼리의
                                                                 순서 조정(▲▼)은 제거했다 — 이 목록이 고정 순서로 재정렬되지 않아 눌러도
                                                                 아무 변화가 보이지 않았고(순서는 오버레이에만 반영), '반응 없는 버튼'으로
                                                                 읽혔다. 고정된 버프가 맨 앞에 오는 동작 자체는 그대로다. -->
                                                            <CheckBox Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Center"
                                                                      IsChecked="{Binding IsPinned, Mode=OneWay}"
                                                                      ToolTip="켜면 표시 순서와 무관하게 버프 오버레이의 가장 앞쪽에 표시됩니다."
                                                                      DataContext="{Binding}" Click="OnBuffPinToggle">
                                                                <TextBlock Text="위치 고정" FontSize="11" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <!-- 기본 Foreground는 로컬 속성이 아니라 Setter로 준다 — 로컬 값은
                                                                             트리거보다 우선순위가 높아 강조가 먹지 않는다. -->
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource Skin.Accent}"/>
                                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </CheckBox>
                                                            <ComboBox Grid.Column="3" Width="128" SelectedIndex="{Binding Mode, Mode=TwoWay}" VerticalAlignment="Center">
                                                                <ComboBoxItem Content="알림끔"/>
                                                                <ComboBoxItem Content="오버레이만"/>
                                                                <ComboBoxItem Content="오버레이+음성"/>
                                                                <ComboBoxItem Content="음성만"/>
                                                            </ComboBox>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ===== 테마 색상 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=theme}">
                        <TextBlock Text="테마 색상" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="유저 이름 색상" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="천족" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.ServerAColor, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="마족" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.ServerBColor, Mode=TwoWay}"/></Grid>

                        <TextBlock Text="미터 바 색상" Style="{StaticResource Label}" Margin="0,12,0,4"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="색상 방식" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" HorizontalAlignment="Left" Width="200" ItemsSource="{Binding BarColorModes}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding Theme.BarColorMode, Mode=TwoWay}"/></Grid>
                        <!-- 내 캐릭터(본인) 색은 두 모드 모두에서 사용 -->
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="내 캐릭터" VerticalAlignment="Center"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.UserBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.UserBarTo, Mode=TwoWay}"/></Grid>

                        <!-- 본인 강조: 기여도 티어 색 -->
                        <StackPanel Visibility="{Binding Theme.BarColorMode, Converter={StaticResource NavVis}, ConverterParameter=self}">
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="일반" VerticalAlignment="Center"/>
                                <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.NormalBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.NormalBarTo, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="경고 (기여도 5% 미만)" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.WarningBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.WarningBarTo, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="에러 (기여도 3% 미만)" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.ErrorBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.ErrorBarTo, Mode=TwoWay}"/></Grid>
                        </StackPanel>

                        <!-- 직업 강조: 직업별 색 (기본값 = 조인 패널과 동일 팔레트) -->
                        <StackPanel Visibility="{Binding Theme.BarColorMode, Converter={StaticResource NavVis}, ConverterParameter=job}">
                            <TextBlock Text="직업별 색상" Style="{StaticResource Label}" Margin="0,8,0,4"/>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="검성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarGladiator, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="수호성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarTemplar, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="궁성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarRanger, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="살성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarAssassin, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="마도성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarSorcerer, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="치유성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarCleric, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="정령성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarElementalist, Mode=TwoWay}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="호법성" VerticalAlignment="Center"/>
                                <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.JobBarChanter, Mode=TwoWay}"/></Grid>
                        </StackPanel>

                        <TextBlock Text="미터 텍스트 색상" Style="{StaticResource Label}" Margin="0,12,0,4"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="누적 / 전투력" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatAmount, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DPS / 피해량" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatDps, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="퍼센트" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.MeterStatPercent, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="전투 시간" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.CombatTimeColor, Mode=TwoWay}"/></Grid>

                        <TextBlock Text="보스 / 전투 기록" Style="{StaticResource Label}" Margin="0,12,0,4"/>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="타겟 / 전투 기록" VerticalAlignment="Center"/>
                            <controls:GradientRowControl Grid.Column="1" FromColor="{Binding Theme.BossBarFrom, Mode=TwoWay}" ToColor="{Binding Theme.BossBarTo, Mode=TwoWay}"/></Grid>
                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="남은 체력 / 경과 시간" VerticalAlignment="Center"/>
                            <controls:ColorSwatchButton Grid.Column="1" Color="{Binding Theme.BossRightValue, Mode=TwoWay}"/></Grid>

                        <Button Content="테마 색상 초기화" HorizontalAlignment="Left" Margin="0,14,0,0" Click="OnResetTheme"/>
                    </StackPanel>

                    <!-- ===== 단축키 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=hotkeys}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="단축키" Style="{StaticResource SectionHeader}"/>
                            <!-- Hover help: modifier-less single-key hotkeys are allowed (kept by request) but are
                                 registered SYSTEM-WIDE, so a bare key like F11 fires in-game too and can silently
                                 hide the overlay. Warn instead of restricting. See
                                 overlay-autohide-unpark-on-return-rootcause. -->
                            <Border Width="18" Height="18" CornerRadius="9" Margin="8,0,0,10" VerticalAlignment="Center"
                                    Cursor="Help" Background="{DynamicResource Skin.AccentSoft}"
                                    BorderBrush="{DynamicResource Skin.Border}" BorderThickness="1"
                                    ToolTipService.InitialShowDelay="150" ToolTipService.ShowDuration="60000">
                                <TextBlock Text="?" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{DynamicResource Skin.Accent}"/>
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="340" Background="{DynamicResource Skin.PanelBg}"
                                             BorderBrush="{DynamicResource Skin.Border}">
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Skin.Fg}">
                                            단축키에는 <Run FontWeight="Bold">Ctrl / Alt / Shift 중 하나 이상</Run>을 함께 지정하길 권장합니다.<LineBreak/><LineBreak/>
                                            수식키 없는 단일 키(예: F11)도 지정할 수 있지만, 이 경우 <Run FontWeight="Bold">시스템 전역</Run>으로 등록되어 게임·다른 프로그램에서 그 키를 눌러도 동작합니다. 예를 들어 '표시 / 숨김'을 F11로 두면 게임 중 F11을 누르는 순간 오버레이가 숨겨지고, 같은 키를 다시 누르거나 트레이 아이콘으로만 되돌릴 수 있습니다.<LineBreak/><LineBreak/>
                                            수식키를 함께 쓰면 이런 의도치 않은 동작을 막을 수 있습니다.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="단일 키 또는 Ctrl/Alt 조합으로 지정할 수 있습니다. (수식키 없는 단일 키는 권장하지 않습니다 — ⓘ 참고)  각 항목 오른쪽의 지우기 버튼을 누르면 미지정(사용 안 함)으로 둘 수 있습니다." Style="{StaticResource SettingDesc}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="전투 초기화" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <local:HotkeyCaptureBox x:Name="ResetHotkeyBox" Grid.Column="0" Combo="{Binding PendingReset, Mode=TwoWay}"/>
                                <Button Grid.Column="1" Style="{StaticResource HotkeyClearButton}"
                                        Click="OnClearHotkey" Tag="{Binding ElementName=ResetHotkeyBox}"/>
                            </Grid>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="표시 / 숨김" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <local:HotkeyCaptureBox x:Name="VisibilityHotkeyBox" Grid.Column="0" Combo="{Binding PendingVisibility, Mode=TwoWay}"/>
                                <Button Grid.Column="1" Style="{StaticResource HotkeyClearButton}"
                                        Click="OnClearHotkey" Tag="{Binding ElementName=VisibilityHotkeyBox}"/>
                            </Grid>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="클릭 통과 / 잠금" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <local:HotkeyCaptureBox x:Name="ClickThroughHotkeyBox" Grid.Column="0" Combo="{Binding PendingClickThrough, Mode=TwoWay}"/>
                                <Button Grid.Column="1" Style="{StaticResource HotkeyClearButton}"
                                        Click="OnClearHotkey" Tag="{Binding ElementName=ClickThroughHotkeyBox}"/>
                            </Grid>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="허수아비 모드 켜기/끄기" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <local:HotkeyCaptureBox x:Name="DummyToggleHotkeyBox" Grid.Column="0" Combo="{Binding PendingDummyToggle, Mode=TwoWay}"/>
                                <Button Grid.Column="1" Style="{StaticResource HotkeyClearButton}"
                                        Click="OnClearHotkey" Tag="{Binding ElementName=DummyToggleHotkeyBox}"/>
                            </Grid>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="허수아비 DPS 초기화" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <local:HotkeyCaptureBox x:Name="DummyResetHotkeyBox" Grid.Column="0" Combo="{Binding PendingDummyReset, Mode=TwoWay}"/>
                                <Button Grid.Column="1" Style="{StaticResource HotkeyClearButton}"
                                        Click="OnClearHotkey" Tag="{Binding ElementName=DummyResetHotkeyBox}"/>
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <!-- ===== 고급 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=advanced}">
                        <TextBlock Text="창 동작" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="닫기 버튼 동작" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="X 버튼을 눌렀을 때 트레이로 보낼지 종료할지 선택합니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding CloseActions}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding CloseAction}"/>
                        </Grid>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="캡처 방식" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="패킷 캡처 백엔드" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="WinDivert가 막히면 Npcap으로 전환할 수 있습니다. (재시작 후 적용)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="190" VerticalAlignment="Center" ItemsSource="{Binding CaptureBackends}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding CaptureBackend}"/>
                        </Grid>
                        <!-- 서버 IP/포트는 자동 감지되며 사용자가 직접 설정할 일이 없어 UI에서 숨김
                             (값/저장 경로는 SettingsViewModel.ServerIp/Port/SaveServer에 그대로 보존). -->

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="렌더링 / 호환성" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="FreeSync / G-Sync 호환 모드" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="가변 주사율 디스플레이에서 오버레이가 화면 끊김을 일으키지 않도록 소프트웨어 렌더링을 사용합니다 (권장). 끄면 GPU 렌더링을 시도합니다. (재시작 후 적용)" Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding VrrCompatMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ===== 공개 설정 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=stats}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="공개 설정 (익명 통계)" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource HelpDot}" Margin="8,0,0,10">
                                <TextBlock Style="{StaticResource HelpQ}"/>
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="420" Background="{DynamicResource Skin.PanelBg}" BorderBrush="{DynamicResource Skin.Border}">
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Skin.Fg}">
                                            게임에서 측정한 보스 전투 기록을 <Run FontWeight="Bold">익명</Run>으로 통계 서버에 보낼지 설정합니다. 닉네임·서버는 식별 불가능한 해시로 처리됩니다.<LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold">■ 스위치 3종</Run> (바꾼 뒤 <Run FontWeight="Bold">적용</Run>을 눌러야 반영)<LineBreak/>
                                            · 동의 — 통계 수집 기본 동의. 끄면 업로드·공개가 모두 중지됩니다.<LineBreak/>
                                            · 업로드 활성화 — 동의 상태에서 실제 전송을 켜고 끕니다 (내 PC에만 저장, 서버 전송 안 함).<LineBreak/>
                                            · 캐릭터 공개 — 통계 사이트에 내 캐릭터 공개 표시 여부 (끄면 익명 집계).<LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold">■ 적용</Run> — 현재 스위치를 저장·전송(보내기). 동의 ON이면 동의 정보를 서버로 보내고, OFF면 내 PC에만 '거부'로 기록합니다. 전송 실패 시 상태가 sync_failed가 되고 업로드는 자동으로 꺼집니다.<LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold">■ 서버 동기화</Run> — 서버에 저장된 내 동의 상태를 가져와 스위치를 맞춥니다(가져오기). 스위치를 바꾼 뒤 적용 없이 누르면 바뀐 내용이 서버 값으로 덮어써집니다.<LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold">■ 상태 표시</Run> — &lt;상태&gt; · &lt;동기화&gt; 형식. accepted/declined=동의/거부, synced=서버 반영, local=내 PC에만, sync_failed=전송 실패, identity_missing=캐릭터 미접속.<LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold">■ 업로드·대기·건너뜀·실패</Run> — 이번 실행의 집계. '건너뜀'은 보스 킬이 아니거나 중복이라 제외된 것으로 정상입니다.<LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold">■ 내 캐릭터 통계 보기</Run> — 익명 식별값으로 내가 올린 전투 기록만 웹에서 봅니다(닉네임·서버 비공개). 미터기 재설치·다른 PC·예전 전투도 포함.<LineBreak/><LineBreak/>
                                            동의는 캐릭터별로 기억되며, 캐릭터가 접속해 있어야 설정할 수 있습니다.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                            </Border>
                        </StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="익명 통계 업로드에 동의" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="캐릭터별로 동의가 기억됩니다." Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ConsentAccepted}" IsEnabled="{Binding CharacterDetected}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="업로드 활성화" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding UploadEnabled}" IsEnabled="{Binding CharacterDetected}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="캐릭터 공개" Style="{StaticResource SettingTitle}" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding PublicCharacter}" IsEnabled="{Binding CharacterDetected}"/>
                        </Grid>
                        <TextBlock Text="캐릭터 접속 후 동의할 수 있어요" Foreground="#FFCC8800" FontSize="11"
                                   Visibility="{Binding CharacterDetected, Converter={StaticResource BoolToVisInverse}, FallbackValue=Collapsed}"/>
                        <TextBlock Text="{Binding ConsentStatus}" Style="{StaticResource SettingDesc}" Margin="0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="적용" Click="OnApplyConsent" Margin="0,0,8,0"/>
                            <Button Content="서버 동기화" Click="OnRefreshConsent"/>
                        </StackPanel>
                        <TextBlock Text="{Binding UploadStatus}" Style="{StaticResource SettingDesc}" Margin="0,8,0,0"/>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="내 캐릭터 관리" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                        <TextBlock Text="익명 통계에 동의한 내 캐릭터들의 공개 여부를 바꾸거나 동의를 철회할 수 있습니다. (철회 시 이후 업로드가 중단됩니다.)"
                                   Style="{StaticResource SettingDesc}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ConsentCharacters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Skin.PanelBg}" BorderBrush="{DynamicResource Skin.Border}"
                                            BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Label}" FontWeight="Bold"/>
                                                    <Border Background="{DynamicResource Skin.AccentSoft}" CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                                            VerticalAlignment="Center" Visibility="{Binding CurrentBadgeVisibility}">
                                                        <TextBlock Text="현재 접속" FontSize="10" Foreground="{DynamicResource Skin.Accent}"/>
                                                    </Border>
                                                    <!-- 오드 (aether) chip — matches the meter footer badge; last-seen per character. -->
                                                    <Border Background="{DynamicResource Skin.StatBg}" CornerRadius="4" Padding="5,1" Margin="6,0,0,0"
                                                            VerticalAlignment="Center" Visibility="{Binding AetherVisibility}" ToolTip="오드 (마지막으로 확인된 값)">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path Data="M 5,0 L 10,5 L 5,10 L 0,5 Z" Fill="#7EE7FF" Width="10" Height="10" Stretch="Uniform"
                                                                  VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding AetherText}" Foreground="#7EE7FF" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding SubLabel}" Style="{StaticResource SettingDesc}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="공개" FontSize="10" HorizontalAlignment="Center" Foreground="{DynamicResource Skin.MutedFg}"/>
                                                <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Center"
                                                          IsChecked="{Binding IsPublic, Mode=OneWay}" IsEnabled="{Binding CanSetPublic}"
                                                          ToolTip="{Binding PublicToggleTooltip}" ToolTipService.ShowOnDisabled="True"
                                                          Click="OnToggleCharacterPublic"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="동의 철회" Click="OnRevokeCharacter" IsEnabled="{Binding CanRevoke}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="아직 동의한 캐릭터가 없습니다." Style="{StaticResource SettingDesc}"
                                   Visibility="{Binding HasConsentCharacters, Converter={StaticResource BoolToVisInverse}, FallbackValue=Visible}"/>
                        <TextBlock Text="{Binding ConsentNotice}" TextWrapping="Wrap" Foreground="#FFCC8800" FontSize="12" Margin="0,8,0,0"
                                   Visibility="{Binding HasConsentNotice, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="내 전투 기록" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Button Content="내 캐릭터 통계 보기" Click="OnOpenMyStats" IsEnabled="{Binding CharacterDetected}" HorizontalAlignment="Left"/>
                        <TextBlock Text="캐릭터가 접속해 있어야 열 수 있어요" Style="{StaticResource SettingDesc}" Margin="0,4,0,0"
                                   Visibility="{Binding CharacterDetected, Converter={StaticResource BoolToVisInverse}, FallbackValue=Collapsed}"/>
                    </StackPanel>

                    <!-- ===== 진단 ===== -->
                    <!-- ===== 리플레이 (베타) ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=replay}">
                        <TextBlock Text="전투 리플레이 (베타)" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource SettingDesc}" Margin="0,0,0,10"
                                   Text="전투 중 파티원과 보스의 이동을 기록해, 던전 지도 위에서 되감아 볼 수 있습니다. 보스 기믹의 장판도 함께 표시됩니다."/>

                        <Border Background="{DynamicResource Skin.AccentSoft}" BorderBrush="{DynamicResource Skin.Accent}"
                                BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,14">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource Skin.Fg}"
                                       Text="⚠ 베타 기능입니다. 일부 던전이나 상황에서 위치가 비거나, 지도·장판이 어긋나게 표시될 수 있습니다. 특히 본인 위치는 패킷 제약상 스킬 시전 시점에만 정확하며, 그 사이 구간은 속 빈 링(마지막 위치)으로 표시됩니다. DPS 집계에는 영향을 주지 않습니다."/>
                        </Border>

                        <TextBlock Visibility="{Binding ReplayUnavailableVisibility}" Style="{StaticResource SettingDesc}"
                                   Margin="0,0,0,12" Foreground="{DynamicResource Skin.MutedFg}"
                                   Text="이 빌드에는 리플레이 모듈이 포함되어 있지 않아 사용할 수 없습니다."/>

                        <Grid Margin="0,0,0,14" IsEnabled="{Binding ReplayAvailable}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="리플레이 자동 저장" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="전투가 끝날 때마다 이동 기록을 저장합니다. 끄면 아무것도 기록하지 않습니다 (즉시 적용)."/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding RecordReplay}"/>
                        </Grid>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="저장 경로" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Style="{StaticResource SettingDesc}" Margin="0,0,0,8"
                                   Text="기록은 전투당 파일 하나(json)로 저장되며, 최근 것부터 일정 개수만 유지됩니다."/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Click="OnPlayReplay" Margin="0,0,8,0" IsEnabled="{Binding ReplayAvailable}"
                                    ToolTip="리플레이 파일(.json)을 선택해 재생합니다">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M 0,0 L 8,5 L 0,10 Z" Fill="{DynamicResource Skin.Accent}" Width="8" Height="10"
                                          Stretch="Uniform" VerticalAlignment="Center" Margin="0,1,7,0"/>
                                    <TextBlock Text="리플레이 재생" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Content="리플레이 폴더 열기" Click="OnOpenReplayFolder"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ===== 허수아비 테스트 ===== -->
                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=dummy}">
                        <TextBlock Text="허수아비 테스트" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource SettingDesc}" Margin="0,0,0,12"
                                   Text="훈련용 허수아비를 때려 DPS를 측정하는 별도 모드입니다. 헤더의 허수아비 버튼(스톱워치)으로도 켜고 끌 수 있습니다."/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="허수 테스트" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="끄면 허수아비 타격이 전투로 잡히지 않습니다. 켜면 허수아비 타격을 전투로 집계합니다 (즉시 적용). 허수아비 전투는 전투 기록에 저장되지 않습니다."/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding DummyTestMode}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="측정 시간" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="설정한 시간이 지나면 계속 때려도 집계가 즉시 멈추고 결과가 고정됩니다. 다시 측정하려면 아래 초기화를 누르세요."/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="130" VerticalAlignment="Center" ItemsSource="{Binding DummyDurations}"
                                      ItemTemplate="{StaticResource OptionItemTemplate}" SelectedValuePath="Value" SelectedValue="{Binding DummyDurationValue}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="허수아비 DPS 초기화" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="빠른 재측정을 위해 허수아비 DPS만 즉시 비웁니다. 저장된 전투 기록·인식 캐릭터는 그대로 보존됩니다."/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="초기화" MinWidth="90" VerticalAlignment="Center" Click="OnResetDummyDps"
                                    ToolTip="허수아비 DPS만 즉시 초기화 (전투 기록은 보존)"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Visibility="{Binding SelectedNav, Converter={StaticResource NavVis}, ConverterParameter=diag}">
                        <TextBlock Text="진단 — 패킷 로깅" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="전투를 기록해 재생 가능한 코퍼스(packet-debug-logs)를 남깁니다. 진단/검증용이며, 켜두면 디스크에 계속 기록됩니다."
                                   Style="{StaticResource SettingDesc}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Button Content="{Binding LoggingButtonLabel}" Width="110" Click="OnToggleLogging" Margin="0,0,8,0"/>
                            <Button Content="로그 폴더 열기" Click="OnOpenLogFolder"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LoggingStatus}" Style="{StaticResource SettingDesc}" Margin="0,6,0,0"/>

                        <Border Style="{StaticResource SectionDivider}"/>
                        <TextBlock Text="위치 초기화" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Text="드래그로 옮긴 창들을 기본 위치로 되돌립니다." Style="{StaticResource SettingDesc}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="미터기 위치" Click="OnResetMeterPosition" Margin="0,0,8,0"/>
                            <Button Content="파티 신청 위치" Click="OnResetJoinPosition" Margin="0,0,8,0"/>
                            <Button Content="전투 기록 위치" Click="OnResetHistoryPosition"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- footer -->
        <Grid Grid.Row="1" Margin="20,10,16,14">
            <!-- 왼쪽: 버전 + Discord(브랜드 색 그대로 채운 버튼). 통계 웹은 좌측 탭 줄로, 후원은 아래 배너 줄로
                 옮겼다 — 저장/취소와 같은 줄에 링크가 셋이나 있으면 무엇이 '설정을 바꾸는 버튼'인지 흐려진다. -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="{Binding Version, StringFormat='waffle_meter v{0}'}" Foreground="{DynamicResource Skin.MutedFg}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <Button Height="32" Cursor="Hand" Click="OnOpenDiscord" Style="{StaticResource BrandButton}"
                        ToolTip="버그 제보와 문의를 받는 공식 디스코드입니다."
                        Background="#FF5865F2" Foreground="White" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" Margin="14,0">
                        <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"
                                   Margin="0,0,7,0"/>
                        <TextBlock Text="Discord" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="기본값 복원" Click="OnResetDefaults" Margin="0,0,8,0"/>
                <Button Content="취소" Width="80" Click="OnCancel" Margin="0,0,8,0"/>
                <Button Content="저장" Width="80" Click="OnSave"/>
            </StackPanel>
        </Grid>

        <!-- 후원 배너. 저장/취소와 같은 줄에 두면 '설정을 바꾸는 버튼'과 섞여 보이므로 창 맨 아래에 가로로
             한 줄을 따로 뒀다. 배너를 눌러도 바로 후원 페이지로 가지 않는다 — 안내창을 먼저 띄워 무엇에
             쓰이는지와 "후원 없이도 전 기능을 쓸 수 있다"를 읽고 나서 결정하게 한다. -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Skin.SoftBorder}"
                Background="#0FF59E0B" Padding="20,12,16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" VerticalAlignment="Center"
                        Background="#1FF59E0B" BorderBrush="#38F59E0B" BorderThickness="1">
                    <TextBlock Text="&#xEB51;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#FFFCD34D"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="개발자 와플 사주기" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Skin.Fg}"/>
                    <TextBlock Text="와플 미터 유지와 더 안정적인 배포를 응원할 수 있습니다. 후원은 선택이며, 하지 않아도 모든 기능을 그대로 쓸 수 있습니다."
                               FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource Skin.MutedFg}"/>
                </StackPanel>
                <Button Grid.Column="2" Height="32" MinWidth="112" VerticalAlignment="Center" Click="OnOpenDonate"
                        Style="{StaticResource BrandButton}" Background="#FFF59E0B" Foreground="#FF3B2600">
                    <TextBlock Text="와플 사주기" FontSize="12.5" FontWeight="SemiBold" Margin="12,0"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
