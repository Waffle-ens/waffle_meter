<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- "Midnight" skin: deeper blue-black with a brighter blue accent. Same key set as Skin.Dark. -->

    <!-- core surfaces -->
    <Color x:Key="Skin.OverlayBgColor">#0A0E18</Color>
    <SolidColorBrush x:Key="Skin.WindowBg" Color="#FF0F1422"/>
    <SolidColorBrush x:Key="Skin.PanelBg" Color="#F7101626"/>
    <SolidColorBrush x:Key="Skin.Fg" Color="#FFE6ECF5"/>
    <SolidColorBrush x:Key="Skin.MutedFg" Color="#AD9FB0CC"/>
    <SolidColorBrush x:Key="Skin.Border" Color="#2E5A78C8"/>
    <SolidColorBrush x:Key="Skin.SoftBorder" Color="#1C5A78C8"/>
    <SolidColorBrush x:Key="Skin.Accent" Color="#FF4F9CF0"/>
    <SolidColorBrush x:Key="Skin.AccentSoft" Color="#1F4F9CF0"/>

    <!-- rows -->
    <SolidColorBrush x:Key="Skin.RowBg" Color="#A3101626"/>
    <SolidColorBrush x:Key="Skin.RowHover" Color="#D11C2840"/>
    <SolidColorBrush x:Key="Skin.RowSelected" Color="#214F9CF0"/>
    <SolidColorBrush x:Key="Skin.RowSelectedBorder" Color="#5C4F9CF0"/>
    <SolidColorBrush x:Key="Skin.StatBg" Color="#5A0A1428"/>
    <SolidColorBrush x:Key="Skin.IconRing" Color="#295A78C8"/>

    <!-- controls -->
    <SolidColorBrush x:Key="Skin.ControlBg" Color="#B3101626"/>
    <SolidColorBrush x:Key="Skin.ControlBorder" Color="#215A78C8"/>
    <SolidColorBrush x:Key="Skin.ControlHover" Color="#EB1C2840"/>
    <SolidColorBrush x:Key="Skin.ButtonBg" Color="#B3151D32"/>
    <SolidColorBrush x:Key="Skin.TabSelectedBg" Color="#FF1B2233"/>

    <!-- detail/history tables -->
    <SolidColorBrush x:Key="Skin.SectionBg" Color="#D6101626"/>
    <SolidColorBrush x:Key="Skin.TableHeadBg" Color="#F01C2840"/>
    <SolidColorBrush x:Key="Skin.TableHeadFg" Color="#FFE6ECF5"/>
    <SolidColorBrush x:Key="Skin.TableRowBg" Color="#94101626"/>
    <SolidColorBrush x:Key="Skin.TableRowAlt" Color="#751C2840"/>
</ResourceDictionary>
