<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- "Light" skin = the dev build's overlayTheme=light palette, ported 1:1 from the React light
         meter tokens (App.tsx light column). Same key set as the dark palettes (SkinManager contract). -->

    <!-- core surfaces -->
    <Color x:Key="Skin.OverlayBgColor">#FAFCFF</Color>
    <SolidColorBrush x:Key="Skin.WindowBg" Color="#FFF4F6FA"/>
    <SolidColorBrush x:Key="Skin.PanelBg" Color="#F7FAFCFF"/>
    <SolidColorBrush x:Key="Skin.Fg" Color="#FF172033"/>
    <SolidColorBrush x:Key="Skin.MutedFg" Color="#B3334155"/>
    <SolidColorBrush x:Key="Skin.Border" Color="#2E0F172A"/>
    <SolidColorBrush x:Key="Skin.SoftBorder" Color="#1C0F172A"/>
    <SolidColorBrush x:Key="Skin.Accent" Color="#FF0F766E"/>
    <SolidColorBrush x:Key="Skin.AccentSoft" Color="#1F0F766E"/>

    <!-- rows -->
    <SolidColorBrush x:Key="Skin.RowBg" Color="#B8FFFFFF"/>
    <SolidColorBrush x:Key="Skin.RowHover" Color="#EBE2E8F0"/>
    <SolidColorBrush x:Key="Skin.RowSelected" Color="#2910B981"/>
    <SolidColorBrush x:Key="Skin.RowSelectedBorder" Color="#61059669"/>
    <SolidColorBrush x:Key="Skin.StatBg" Color="#0E0F172A"/>
    <SolidColorBrush x:Key="Skin.IconRing" Color="#290F172A"/>

    <!-- controls -->
    <SolidColorBrush x:Key="Skin.ControlBg" Color="#B8FFFFFF"/>
    <SolidColorBrush x:Key="Skin.ControlBorder" Color="#210F172A"/>
    <SolidColorBrush x:Key="Skin.ControlHover" Color="#F5E2E8F0"/>
    <SolidColorBrush x:Key="Skin.ButtonBg" Color="#B8FFFFFF"/>
    <SolidColorBrush x:Key="Skin.TabSelectedBg" Color="#FFD6DEE8"/>

    <!-- detail/history tables -->
    <SolidColorBrush x:Key="Skin.SectionBg" Color="#E1E2E8F0"/>
    <SolidColorBrush x:Key="Skin.TableHeadBg" Color="#D6334155"/>
    <SolidColorBrush x:Key="Skin.TableHeadFg" Color="#FFF8FAFC"/>
    <SolidColorBrush x:Key="Skin.TableRowBg" Color="#BDFFFFFF"/>
    <SolidColorBrush x:Key="Skin.TableRowAlt" Color="#D1F1F5F9"/>
</ResourceDictionary>
