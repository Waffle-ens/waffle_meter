<Window x:Class="WaffleMeter.App.Wpf.BuffPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="직업별 버프 선택" Width="440" Height="560"
        WindowStartupLocation="CenterOwner" FontFamily="Segoe UI"
        Background="{DynamicResource Skin.WindowBg}" Foreground="{DynamicResource Skin.Fg}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConv"/>
    </Window.Resources>
    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" Text="오버레이에 표시할 버프를 직업별로 선택하세요."
                   Foreground="{DynamicResource Skin.MutedFg}" FontSize="12" Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top" Text="목록은 전투에서 본인·파티원에게 실제로 적용된 버프가 쌓이며 채워집니다. (소비 아이템·물약 제외)"
                   Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <Button DockPanel.Dock="Bottom" Content="닫기" HorizontalAlignment="Right" MinWidth="80" Margin="0,10,0,0"
                Click="OnClose"/>

        <TextBlock Text="아직 표시된 버프가 없습니다. 전투를 진행하면 여기에 버프가 나타납니다."
                   Foreground="{DynamicResource Skin.MutedFg}" TextWrapping="Wrap" VerticalAlignment="Center"
                   HorizontalAlignment="Center" TextAlignment="Center" Margin="20"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Skin.SoftBorder}" Padding="0,6,0,8" Margin="0,0,0,6">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Job}" FontWeight="Bold" FontSize="13"
                                               Foreground="{DynamicResource Skin.Accent}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="전체 표시" Padding="6,1" FontSize="11" Margin="0,0,4,0"
                                                Tag="{Binding}" Click="OnShowAll"/>
                                        <Button Content="전체 숨김" Padding="6,1" FontSize="11"
                                                Tag="{Binding}" Click="OnHideAll"/>
                                    </StackPanel>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding Shown, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <Image Grid.Column="1" Source="{Binding IconSource}" Width="24" Height="24" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Name}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource Skin.Fg}" FontSize="12"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
