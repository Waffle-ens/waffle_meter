<Window x:Class="WaffleMeter.App.Wpf.DonateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="와플 사주기"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="Height"
        Width="470" WindowStartupLocation="CenterOwner" FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Bullet" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource Skin.Border}" Background="{DynamicResource Skin.PanelBg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <!-- header -->
            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Skin.SoftBorder}" Padding="20,18,20,16">
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="8" Background="#1AF59E0B" BorderBrush="#33F59E0B" BorderThickness="1">
                        <TextBlock Text="&#xEB51;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="#FFFCD34D"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="개발자 와플 사주기" Foreground="{DynamicResource Skin.Fg}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="와플 미터를 계속 굽는 데 보태주실 수 있습니다."
                                   Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Margin="20,16,20,4">
                <!-- 후원이 선택임을 가장 먼저, 가장 눈에 띄게. -->
                <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,14"
                        Background="#1434D399" BorderBrush="#4034D399" BorderThickness="1">
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FFD1FAE5">
                        <Run FontWeight="Bold" Text="후원은 전혀 필수가 아닙니다."/>
                        <Run Text=" 후원하지 않으셔도 와플 미터의 모든 기능을 아무 제한 없이 그대로 쓰실 수 있고, 앞으로도 그럴 겁니다."/>
                    </TextBlock>
                </Border>

                <TextBlock Text="보내주신 금액은 이런 순서로 쓰입니다." FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource Skin.Fg}" Margin="0,0,0,9"/>

                <TextBlock Style="{StaticResource Bullet}">
                    <Run FontWeight="Bold" Text="1. 코드 서명서 구입"/>
                    <LineBreak/>
                    <Run Text="가장 먼저 쓸 곳입니다. 서명이 붙으면 Windows 보안 경고와 SmartScreen 차단이 줄어들어, &quot;이거 켜도 되는 건가&quot; 하는 순간이 사라집니다."/>
                </TextBlock>
                <TextBlock Style="{StaticResource Bullet}">
                    <Run FontWeight="Bold" Text="2. 통계 웹서비스 유지"/>
                    <LineBreak/>
                    <Run Text="전투 기록을 올리고 다시 꺼내 보는 웹서비스의 서버·도메인 유지비로 씁니다."/>
                </TextBlock>
                <TextBlock Style="{StaticResource Bullet}">
                    <Run FontWeight="Bold" Text="3. 추가 기능 개발"/>
                    <LineBreak/>
                    <Run Text="만들다 만 것들과, 만들고 싶은데 아직 손이 못 간 것들에 씁니다."/>
                </TextBlock>
                <TextBlock Style="{StaticResource Bullet}" Margin="0,0,0,2">
                    <Run FontWeight="Bold" Text="4. 그러고도 남는다면"/>
                    <LineBreak/>
                    <Run Text="지속적인 업데이트를 위해 개발자의 사리사욕을 채우는 데 쓰입니다. 밤새 코드를 짜려면 개발자도 뭔가는 먹어야 하거든요."/>
                </TextBlock>
            </StackPanel>

            <!-- footer -->
            <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Skin.SoftBorder}" Background="#08FFFFFF" Padding="20,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="닫기" Click="OnClose" Width="72" Height="30" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{DynamicResource Skin.MutedFg}" BorderThickness="0" Cursor="Hand"/>
                    <Button Click="OnDonate" Height="30" MinWidth="132" Cursor="Hand"
                            Background="#1AF59E0B" Foreground="#FFFCD34D" BorderBrush="#55F59E0B" BorderThickness="1">
                        <TextBlock Text="후원하러 가기" FontWeight="SemiBold" FontSize="12" Margin="10,0"/>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
