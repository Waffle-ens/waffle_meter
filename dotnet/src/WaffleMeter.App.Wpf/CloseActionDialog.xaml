<Window x:Class="WaffleMeter.App.Wpf.CloseActionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="종료"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="Height"
        Width="420" WindowStartupLocation="CenterOwner" FontFamily="Segoe UI">
    <Window.Resources>
        <!-- big flat option button: colored tint + border, dims on hover -->
        <Style x:Key="OptionButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource Skin.Border}" Background="{DynamicResource Skin.PanelBg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <!-- header -->
            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Skin.SoftBorder}" Padding="20,18,20,16">
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="8" Background="#1A2DD4BF" BorderBrush="#332DD4BF" BorderThickness="1">
                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FF7DE8DD"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="종료 버튼 동작 선택" Foreground="{DynamicResource Skin.Fg}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="선택한 방식은 설정에 저장되고, 다음부터 전원 버튼에 바로 적용됩니다."
                                   Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap" MaxWidth="320"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- options -->
            <StackPanel Margin="20,16,20,6">
                <Button Style="{StaticResource OptionButton}" Click="OnTray" Background="#1434D399" BorderBrush="#4034D399">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8" Background="#2334D399" VerticalAlignment="Center">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FF6EE7B7"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="트레이에서 계속 실행" Foreground="#FFD1FAE5" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="창만 숨기고 패킷 캡처와 미터기 동작은 유지합니다." Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource OptionButton}" Click="OnExit" Background="#14FB7185" BorderBrush="#40FB7185">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8" Background="#23FB7185" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FFFDA4AF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="완전히 종료" Foreground="#FFFFE4E6" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="미터기와 백그라운드 동작을 모두 종료합니다." Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- footer -->
            <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Skin.SoftBorder}" Background="#08FFFFFF" Padding="20,10">
                <Button Content="취소" Click="OnCancel" HorizontalAlignment="Right" Width="72" Height="28"
                        Background="Transparent" Foreground="{DynamicResource Skin.MutedFg}" BorderThickness="0" Cursor="Hand"/>
            </Border>
        </StackPanel>
    </Border>
</Window>
