<Window x:Class="WaffleMeter.App.Wpf.PatchNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="패치노트"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="Height" Topmost="True"
        Width="460" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
    <Border CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource Skin.Border}" Background="{DynamicResource Skin.PanelBg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <!-- header -->
            <Grid Margin="20,18,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" VerticalAlignment="Top" Margin="0,0,12,0"
                        Background="#1A2DD4BF" BorderBrush="#332DD4BF" BorderThickness="1">
                    <TextBlock Text="&#xE789;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FF7DE8DD"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Foreground="{DynamicResource Skin.Fg}" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="이번 업데이트에서 달라진 점" Foreground="{DynamicResource Skin.MutedFg}" FontSize="12" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" Content="&#xE8BB;" Click="OnClose" Style="{StaticResource HeaderCloseButton}" VerticalAlignment="Top"/>
            </Grid>

            <!-- notes (populated in code-behind) -->
            <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto" Margin="20,0,12,4" Padding="0,0,8,0">
                <StackPanel x:Name="NotesPanel"/>
            </ScrollViewer>

            <!-- footer -->
            <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Skin.SoftBorder}" Background="#08FFFFFF" Padding="20,10" Margin="0,8,0,0">
                <Button Content="확인" Click="OnClose" Height="30" Padding="18,0" HorizontalAlignment="Right"
                        Background="#FF0891B2" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>
    </Border>
</Window>
