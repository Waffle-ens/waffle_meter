<Window x:Class="WaffleMeter.App.Wpf.ReplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="전투 리플레이" Height="640" Width="900" MinHeight="460" MinWidth="640"
        Background="{DynamicResource Skin.WindowBg}" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <!-- Chrome follows the meter's own skin (Skin.* via DynamicResource, so a skin swap re-themes this
         window too): teal accent, slate surfaces, pill controls. The transport bar is the only bespoke
         piece — WPF's stock Button/Slider look nothing like the rest of the app. -->
    <Window.Resources>
        <Style x:Key="TransportButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
            <Setter Property="Background" Value="{DynamicResource Skin.ControlBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Skin.AccentSoft}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Skin.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Speed: a pill group, the active rate filled with the accent. -->
        <Style x:Key="SpeedPill" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" CornerRadius="12" Padding="8,0" Background="Transparent"
                                BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Skin.AccentSoft}"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource Skin.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Skin.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrub bar: a hairline track, accent up to the playhead, a small round grip. -->
        <Style x:Key="ScrubThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Width="14" Height="14" Background="Transparent">
                            <Ellipse x:Name="grip" Width="11" Height="11"
                                     Fill="{DynamicResource Skin.Accent}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="grip" Property="Width" Value="14"/>
                                <Setter TargetName="grip" Property="Height" Value="14"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrubTrackPiece" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2" Height="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrubSliderStyle" TargetType="Slider">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="18" VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" VerticalAlignment="Center"
                                    Background="{DynamicResource Skin.ControlBg}"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrubTrackPiece}"
                                                  Background="{DynamicResource Skin.Accent}"
                                                  Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrubThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrubTrackPiece}"
                                                  Background="Transparent"
                                                  Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <Border Grid.Row="0" Background="{DynamicResource Skin.PanelBg}" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource Skin.SoftBorder}">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="HeaderText" DockPanel.Dock="Left" Margin="14,9"
                           Foreground="{DynamicResource Skin.Fg}"
                           FontSize="14" FontWeight="SemiBold" Text="전투 리플레이"/>
                <TextBlock x:Name="BossBadge" DockPanel.Dock="Right" Margin="14,9"
                           Foreground="{DynamicResource Skin.MutedFg}" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- map + overlays -->
        <Grid Grid.Row="1">
            <Border x:Name="MapBorder" Background="{DynamicResource Skin.StatBg}" Margin="8" CornerRadius="6"
                    ClipToBounds="True" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1">
                <Canvas x:Name="MapCanvas" Background="Transparent" ClipToBounds="True"
                        MouseMove="MapCanvas_MouseMove" MouseLeftButtonDown="MapCanvas_MouseDown"
                        MouseLeave="MapCanvas_MouseLeave" MouseWheel="MapCanvas_MouseWheel"
                        MouseRightButtonDown="MapCanvas_MouseRightButtonDown"
                        MouseRightButtonUp="MapCanvas_MouseRightButtonUp"/>
            </Border>

            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16"
                    Background="{DynamicResource Skin.PanelBg}" BorderBrush="{DynamicResource Skin.SoftBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="9,7" MaxHeight="320">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="LegendPanel"/>
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="EmptyNotice" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource Skin.MutedFg}" FontSize="14" Visibility="Collapsed"
                       Text="이 전투에는 위치 데이터가 없습니다"/>

            <TextBlock x:Name="HoverInfo" IsHitTestVisible="False" HorizontalAlignment="Right"
                       VerticalAlignment="Bottom" Margin="16"
                       Foreground="{DynamicResource Skin.Fg}" FontSize="12"/>

            <TextBlock IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       Margin="16,0,0,34" Opacity="0.55" Foreground="{DynamicResource Skin.MutedFg}" FontSize="11"
                       Text="속 빈 링 = 위치 미상 · 본인 위치는 패킷 제약상 스킬 시전 시점에만 정확합니다"/>

            <TextBlock IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       Margin="16" Opacity="0.55" Foreground="{DynamicResource Skin.MutedFg}" FontSize="11"
                       Text="휠 = 확대/축소 · 우클릭 드래그 = 이동 · 더블클릭 = 전투 화면으로 복귀"/>

            <Popup x:Name="StackPopup" AllowsTransparency="True" Placement="Absolute" StaysOpen="False">
                <Border Background="{DynamicResource Skin.PanelBg}" BorderBrush="{DynamicResource Skin.Border}"
                        BorderThickness="1" CornerRadius="6" Padding="8">
                    <StackPanel x:Name="StackList"/>
                </Border>
            </Popup>
        </Grid>

        <!-- transport -->
        <Border Grid.Row="2" Background="{DynamicResource Skin.PanelBg}" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource Skin.SoftBorder}">
            <DockPanel LastChildFill="True" Margin="10,8">
                <Button x:Name="PlayButton" DockPanel.Dock="Left" Style="{StaticResource TransportButton}"
                        Content="▶" Margin="0,0,10,0" Click="PlayButton_Click"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                    <TextBlock x:Name="TimeText" Foreground="{DynamicResource Skin.MutedFg}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"
                               Text="0:00 / 0:00" MinWidth="86" TextAlignment="Right"/>
                    <RadioButton Style="{StaticResource SpeedPill}" Content="0.5x" Tag="0.5" Checked="Speed_Checked"/>
                    <RadioButton Style="{StaticResource SpeedPill}" Content="1x" Tag="1" IsChecked="True" Checked="Speed_Checked"/>
                    <RadioButton Style="{StaticResource SpeedPill}" Content="2x" Tag="2" Checked="Speed_Checked"/>
                    <RadioButton Style="{StaticResource SpeedPill}" Content="4x" Tag="4" Checked="Speed_Checked"/>
                </StackPanel>

                <Slider x:Name="ScrubSlider" Style="{StaticResource ScrubSliderStyle}" VerticalAlignment="Center"
                        Minimum="0" Maximum="1000" ValueChanged="ScrubSlider_ValueChanged"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
