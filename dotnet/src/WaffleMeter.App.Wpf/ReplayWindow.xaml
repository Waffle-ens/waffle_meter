<Window x:Class="WaffleMeter.App.Wpf.ReplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="전투 리플레이" Height="640" Width="900" MinHeight="460" MinWidth="640"
        Background="#15171C" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <DockPanel Grid.Row="0" Background="#1C1F26" LastChildFill="False">
            <TextBlock x:Name="HeaderText" DockPanel.Dock="Left" Margin="12,8" Foreground="#E6E8EC"
                       FontSize="14" FontWeight="SemiBold" Text="전투 리플레이"/>
            <TextBlock x:Name="BossBadge" DockPanel.Dock="Right" Margin="12,8" Foreground="#9AA0AA" FontSize="12"/>
        </DockPanel>

        <!-- map + overlays -->
        <Grid Grid.Row="1">
            <Border x:Name="MapBorder" Background="#0E1014" Margin="8" CornerRadius="6" ClipToBounds="True">
                <Canvas x:Name="MapCanvas" Background="Transparent" ClipToBounds="True"
                        MouseMove="MapCanvas_MouseMove" MouseLeftButtonDown="MapCanvas_MouseDown"
                        MouseLeave="MapCanvas_MouseLeave" MouseWheel="MapCanvas_MouseWheel"
                        MouseRightButtonDown="MapCanvas_MouseRightButtonDown"
                        MouseRightButtonUp="MapCanvas_MouseRightButtonUp"/>
            </Border>

            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16"
                    Background="#CC1C1F26" CornerRadius="6" Padding="8" MaxHeight="320">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="LegendPanel"/>
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="EmptyNotice" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#6B7280" FontSize="14" Visibility="Collapsed"
                       Text="이 전투에는 위치 데이터가 없습니다"/>

            <TextBlock x:Name="HoverInfo" IsHitTestVisible="False" HorizontalAlignment="Right"
                       VerticalAlignment="Bottom" Margin="16" Foreground="#C8CCD2" FontSize="12"/>

            <TextBlock IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       Margin="16" Foreground="#6B7280" FontSize="11"
                       Text="휠 = 확대/축소 · 우클릭 드래그 = 이동 · 더블클릭 = 전투 화면으로 복귀"/>

            <Popup x:Name="StackPopup" AllowsTransparency="True" Placement="Absolute" StaysOpen="False">
                <Border Background="#F21C1F26" BorderBrush="#3A3F4A" BorderThickness="1" CornerRadius="6" Padding="8">
                    <StackPanel x:Name="StackList"/>
                </Border>
            </Popup>
        </Grid>

        <!-- controls -->
        <DockPanel Grid.Row="2" Background="#1C1F26" LastChildFill="True">
            <Button x:Name="PlayButton" DockPanel.Dock="Left" Content="▶" Width="40" Height="30"
                    Margin="8,8,4,8" Click="PlayButton_Click"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="4,8,8,8">
                <TextBlock x:Name="TimeText" Foreground="#C8CCD2" VerticalAlignment="Center" Margin="6,0"
                           Text="0:00 / 0:00" MinWidth="92"/>
                <Button Content="0.5x" Width="42" Margin="2,0" Click="Speed_Click" Tag="0.5"/>
                <Button Content="1x" Width="38" Margin="2,0" Click="Speed_Click" Tag="1"/>
                <Button Content="2x" Width="38" Margin="2,0" Click="Speed_Click" Tag="2"/>
                <Button Content="4x" Width="38" Margin="2,0" Click="Speed_Click" Tag="4"/>
            </StackPanel>
            <Slider x:Name="ScrubSlider" VerticalAlignment="Center" Margin="8,0" Minimum="0" Maximum="1000"
                    IsMoveToPointEnabled="True" ValueChanged="ScrubSlider_ValueChanged"/>
        </DockPanel>
    </Grid>
</Window>
