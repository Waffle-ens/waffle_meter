<Window x:Class="WaffleMeter.App.Wpf.StatsConsentModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="통계 동의"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="Height"
        Width="420" WindowStartupLocation="CenterOwner" FontFamily="Segoe UI">
    <Window.Resources>
        <!-- compact toggle switch (emerald when on) -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track" Width="40" Height="22" CornerRadius="11" Background="{DynamicResource Skin.ControlBg}"
                                BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1">
                            <Border x:Name="thumb" Width="16" Height="16" CornerRadius="8" Background="{DynamicResource Skin.MutedFg}"
                                    HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#FF10B981"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="#FF10B981"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="thumb" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource Skin.Border}" Background="{DynamicResource Skin.PanelBg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <!-- header -->
            <StackPanel Margin="20,18,20,4">
                <Border Width="40" Height="40" CornerRadius="8" Background="#1A2DD4BF" BorderBrush="#332DD4BF" BorderThickness="1" HorizontalAlignment="Left">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FF7DE8DD" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="전투 통계 수집 동의" Foreground="{DynamicResource Skin.Fg}" FontSize="16" FontWeight="Bold" Margin="0,10,0,0"/>
                <TextBlock x:Name="DescText" Foreground="{DynamicResource Skin.MutedFg}" FontSize="12" LineHeight="18" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- info cards + public toggle -->
            <StackPanel Margin="20,8,20,6">
                <Border CornerRadius="6" Background="#0AFFFFFF" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#FF6EE7B7" VerticalAlignment="Top" Margin="0,1,10,0"/>
                        <TextBlock Text="원본 패킷은 전송하지 않고, 본인 캐릭터의 전투 요약과 스킬/버프 지표만 전송합니다."
                                   Foreground="{DynamicResource Skin.Fg}" FontSize="12" LineHeight="18" TextWrapping="Wrap" MaxWidth="320"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="6" Background="#0AFFFFFF" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#FF7DD3FC" VerticalAlignment="Top" Margin="0,1,10,0"/>
                        <TextBlock Text="파티원은 닉네임 없이 직업 구성과 시너지 수만 사용합니다."
                                   Foreground="{DynamicResource Skin.Fg}" FontSize="12" LineHeight="18" TextWrapping="Wrap" MaxWidth="320"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="6" Background="#0AFFFFFF" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1" Padding="12,10">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="내 캐릭터 통계 공개" Foreground="{DynamicResource Skin.Fg}" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="끄면 비공개 업로드만 허용됩니다." Foreground="{DynamicResource Skin.MutedFg}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="PublicToggle" Style="{StaticResource ToggleSwitch}" IsChecked="True" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- footer -->
            <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Skin.SoftBorder}" Background="#08FFFFFF" Padding="20,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="동의하지 않음" Click="OnDecline" Height="30" Padding="12,0" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{DynamicResource Skin.MutedFg}" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="동의하고 자동 업로드" Click="OnAccept" Height="30" Padding="14,0"
                            Background="#FF0891B2" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
