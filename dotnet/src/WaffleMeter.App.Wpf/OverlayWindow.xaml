<Window x:Class="WaffleMeter.App.Wpf.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="waffle_meter"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Left="40" Top="40"
        FontFamily="Segoe UI">
    <Window.Resources>
        <local:RatioToStarConverter x:Key="RatioToStar"/>
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="설정" Click="OnSettings"/>
            <MenuItem Header="종료" Click="OnExit"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Border Background="#CC1E1E1E" CornerRadius="6" Padding="8" MinWidth="380">
        <StackPanel>
            <DockPanel LastChildFill="False" Margin="0,0,0,6" MouseLeftButtonDown="OnDragHandle" Background="Transparent">
                <TextBlock Text="{Binding TargetName}" Foreground="#FFEEEEEE" FontWeight="Bold" FontSize="13"/>
                <TextBlock Text="{Binding Duration}" Foreground="#FFBBBBBB" DockPanel.Dock="Right"/>
            </DockPanel>

            <TextBlock Text="전투 대기 중" Foreground="#FF888888" HorizontalAlignment="Center"
                       Margin="0,8" Visibility="{Binding PlaceholderVisibility}"/>

            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2" Background="Transparent" MouseLeftButtonUp="OnRowClick" Cursor="Hand">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="3"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Rank}" Foreground="#FF888888" FontSize="11"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Foreground="{Binding NameBrush}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                    <Border Background="#22FFFFFF" CornerRadius="3" Padding="4,0" Margin="6,0,0,0"
                                            VerticalAlignment="Center" Visibility="{Binding PowerVisible}">
                                        <TextBlock Text="{Binding PowerText}" Foreground="#FFD7BA7D" FontSize="10"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding DamageText}" Foreground="#FFF8FAFC" Margin="8,0,8,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding PercentText}" Foreground="#FF8EE6CF"
                                           MinWidth="46" TextAlignment="Right"/>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                    <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{Binding FillBrush}" CornerRadius="1.5"/>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding Status}" Foreground="#FF888888" FontSize="10" Margin="0,6,0,0"/>
        </StackPanel>
    </Border>
</Window>
