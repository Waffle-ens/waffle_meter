<Window x:Class="WaffleMeter.App.Wpf.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="waffle_meter"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Left="40" Top="40"
        FontFamily="Segoe UI">
    <Window.Resources>
        <local:RatioToStarConverter x:Key="RatioToStar"/>
        <local:FontFamilyConverter x:Key="FontConv"/>
        <local:RowHeightToFontSizeConverter x:Key="FontSize"/>
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="설정" Click="OnSettings"/>
            <MenuItem Header="종료" Click="OnExit"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Border CornerRadius="6" Padding="10,8" MinWidth="380"
            TextElement.FontFamily="{Binding Settings.FontFamily, Converter={StaticResource FontConv}}">
        <Border.Background>
            <SolidColorBrush Color="{DynamicResource Skin.OverlayBgColor}" Opacity="{Binding Settings.MeterOpacity}"/>
        </Border.Background>
        <StackPanel>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0" LastChildFill="False" MouseLeftButtonDown="OnDragHandle" Background="Transparent">
                    <TextBlock Text="{Binding TargetName}" Foreground="#FFEEEEEE" FontWeight="Bold" FontSize="13"/>
                    <TextBlock Text="{Binding Duration}" Foreground="{Binding CombatTimeBrush}" DockPanel.Dock="Right" Margin="8,0"/>
                    <TextBlock Text="{Binding TargetHpText}" Foreground="{Binding CombatTimeBrush}" DockPanel.Dock="Right"
                               Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                </DockPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⟳" Click="OnResetButton" ToolTip="전투 초기화" Width="22" Height="20" Padding="0"
                            Background="Transparent" Foreground="#FFCCCCCC" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="⧉" Click="OnTaskbarButton" ToolTip="작업표시줄 / Alt+Tab 모드" Width="22" Height="20" Padding="0"
                            Background="Transparent" Foreground="#FFCCCCCC" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="⚙" Click="OnSettingsButton" ToolTip="설정" Width="22" Height="20" Padding="0"
                            Background="Transparent" Foreground="#FFCCCCCC" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="✕" Click="OnExitButton" ToolTip="종료" Width="22" Height="20" Padding="0"
                            Background="Transparent" Foreground="#FFCC6666" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="전투 대기 중" Foreground="#FF888888" HorizontalAlignment="Center"
                       Margin="0,8" Visibility="{Binding PlaceholderVisibility}"/>

            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Padding="4,2" Margin="0,2" Cursor="Hand"
                                MouseLeftButtonUp="OnRowClick" MinHeight="{Binding RowHeight}">
                            <Border.Style>
                                <!-- Background set in the style (NOT as a local value) so the hover trigger wins. -->
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="2"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource Skin.StatBg}" BorderBrush="#1C94A3B8" BorderThickness="1"
                                            CornerRadius="6" MinWidth="22" Height="20" Padding="4,0" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Rank}" Foreground="#FFAAAAAA" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.32:9'}"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="{Binding NameBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="150"
                                                   FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.4:10'}"/>
                                        <Border Background="{DynamicResource Skin.StatBg}" BorderBrush="#1C94A3B8" BorderThickness="1" CornerRadius="4"
                                                Padding="4,0" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="{Binding PowerVisible}">
                                            <TextBlock Text="{Binding PowerText}" Foreground="{Binding PowerBrush}"
                                                       FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.32:9'}"/>
                                        </Border>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource Skin.StatBg}" CornerRadius="4" Padding="5,0" Margin="6,0,4,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DamageText}" Foreground="{Binding DamageBrush}"
                                                   FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.4:10'}"/>
                                    </Border>
                                    <Border Grid.Column="3" Background="{DynamicResource Skin.StatBg}" CornerRadius="4" Padding="5,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PercentText}" Foreground="{Binding PercentBrush}" MinWidth="40" TextAlignment="Right"
                                                   FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.4:10'}"/>
                                    </Border>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                        <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding FillBrush}" CornerRadius="1"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding Status}" Foreground="#FF888888" FontSize="10" Margin="0,6,0,0"/>
        </StackPanel>
    </Border>
</Window>
