<Window x:Class="WaffleMeter.App.Wpf.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WaffleMeter.App.Wpf"
        Title="waffle_meter"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        Width="420" Height="300" MinWidth="320" MinHeight="150"
        Left="40" Top="40"
        FontFamily="Segoe UI">
    <Window.Resources>
        <local:RatioToStarConverter x:Key="RatioToStar"/>
        <local:FontFamilyConverter x:Key="FontConv"/>
        <local:RowHeightToFontSizeConverter x:Key="FontSize"/>

        <!-- Header icon button: Segoe MDL2 Assets glyph, transparent until hover (skin row-hover bg +
             brighter fg). One consistent, crisp look for the whole header control row. -->
        <Style x:Key="HeaderIconButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Skin.MutedFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Skin.Fg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Compact opacity slider: thin rounded track, accent fill left of the thumb, small round thumb
             (replaces the default WPF chrome that clashed with the dark overlay). -->
        <Style x:Key="OpacitySlider" TargetType="Slider">
            <Setter Property="Height" Value="16"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="{DynamicResource Skin.ControlBg}"
                                    BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="{DynamicResource Skin.Accent}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="12" Height="12" CornerRadius="6" Cursor="Hand"
                                                        Background="{DynamicResource Skin.Fg}" BorderBrush="{DynamicResource Skin.Accent}" BorderThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Close: same shape, red on hover. -->
        <Style x:Key="HeaderCloseButton" TargetType="Button" BasedOn="{StaticResource HeaderIconButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33E81123"/>
                                <Setter Property="Foreground" Value="#FFF36A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="설정" Click="OnSettings"/>
            <MenuItem Header="종료" Click="OnExit"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Border CornerRadius="6" Padding="10,8"
            TextElement.FontFamily="{Binding Settings.FontFamily, Converter={StaticResource FontConv}}">
        <Border.Background>
            <SolidColorBrush Color="{DynamicResource Skin.OverlayBgColor}" Opacity="{Binding Settings.MeterOpacity}"/>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- left: drag handle + opacity control (React Header left side) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            MouseLeftButtonDown="OnDragHandle" Background="Transparent">
                    <TextBlock Text="투명도" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10" VerticalAlignment="Center" Margin="2,0,6,0"/>
                    <Slider Style="{StaticResource OpacitySlider}" Width="92" VerticalAlignment="Center" Minimum="0.15" Maximum="1.0"
                            SmallChange="0.05" LargeChange="0.1" Value="{Binding Settings.MeterOpacity, Mode=TwoWay}"/>
                </StackPanel>
                <!-- right: control buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderIconButton}" Content="&#xE771;" Click="OnThemeButton" ToolTip="테마 변경"/>
                    <Button Style="{StaticResource HeaderIconButton}" Content="&#xE72C;" Click="OnResetButton" ToolTip="전투 초기화"/>
                    <Button Style="{StaticResource HeaderIconButton}" Content="&#xE8A7;" Click="OnTaskbarButton" ToolTip="작업표시줄 / Alt+Tab 모드"/>
                    <Button Style="{StaticResource HeaderIconButton}" Content="&#xE8FA;" Click="OnJoinButton" ToolTip="파티 신청"/>
                    <Button Style="{StaticResource HeaderIconButton}" Content="&#xE81C;" Click="OnHistoryButton" ToolTip="전투 기록"/>
                    <Button Style="{StaticResource HeaderIconButton}" Content="&#xE713;" Click="OnSettingsButton" ToolTip="설정"/>
                    <Button Style="{StaticResource HeaderCloseButton}" Content="&#xE8BB;" Click="OnExitButton" ToolTip="종료"/>
                </StackPanel>
            </Grid>

            <!-- target-info bar (React TargetInfo.tsx): above the rows, shown when there are rows -->
            <Border Grid.Row="1" CornerRadius="6" Padding="8,0" Margin="0,0,0,6" Height="26" ClipToBounds="True"
                    Background="{DynamicResource Skin.RowBg}" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1"
                    Visibility="{Binding TargetInfoVisibility}">
                <Grid>
                    <!-- bottom HP-fill bar -->
                    <Grid VerticalAlignment="Bottom" Height="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding TargetHpRatio, Converter={StaticResource RatioToStar}}"/>
                            <ColumnDefinition Width="{Binding TargetHpRest, Converter={StaticResource RatioToStar}}"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{Binding BossBarBrush}"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- left accent rail -->
                        <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="0,4,8,4" Background="{Binding BossBarBrush}"/>
                        <Image Grid.Column="1" Source="{Binding BossIcon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding TargetName}" Foreground="{DynamicResource Skin.Fg}" FontWeight="SemiBold"
                                   FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="3" Text="{Binding TargetHpText}" Foreground="{Binding CombatTimeBrush}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,0,0" Visibility="{Binding TargetHpVisibility}"/>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
            <TextBlock Text="전투 대기 중" Foreground="{DynamicResource Skin.MutedFg}" HorizontalAlignment="Center"
                       Margin="0,8" Visibility="{Binding PlaceholderVisibility}"/>

            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="6" Padding="5,3" Margin="0,2" Cursor="Hand" BorderThickness="1"
                                ClipToBounds="True" MouseLeftButtonUp="OnRowClick" MinHeight="{Binding RowHeight}">
                            <Border.Style>
                                <!-- Resting card fill + soft border (matches React .meter-row); hover lightens. -->
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource Skin.RowBg}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource Skin.SoftBorder}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Skin.RowHover}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Skin.Border}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="2"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- left accent rail -->
                                    <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="0,2,8,2" VerticalAlignment="Stretch"
                                            Background="{Binding FillBrush}" Opacity="{Binding AccentOpacity}"/>
                                    <!-- rank -->
                                    <Border Grid.Column="1" Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1"
                                            CornerRadius="4" MinWidth="22" Height="20" Padding="4,0" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Rank}" Foreground="{DynamicResource Skin.MutedFg}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.32:9'}"/>
                                    </Border>
                                    <!-- job icon -->
                                    <Border Grid.Column="2" Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.IconRing}" BorderThickness="1"
                                            CornerRadius="6" Margin="0,0,8,0" VerticalAlignment="Center"
                                            Width="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.66:18'}"
                                            Height="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.66:18'}">
                                        <Image Source="{Binding IconSource}" Stretch="Uniform" Margin="2"/>
                                    </Border>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="{Binding NameBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="150"
                                                   FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.4:10'}"/>
                                        <Border Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1" CornerRadius="4"
                                                Padding="4,0" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="{Binding PowerVisible}">
                                            <TextBlock Text="{Binding PowerText}" Foreground="{Binding PowerBrush}"
                                                       FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.32:9'}"/>
                                        </Border>
                                    </StackPanel>
                                    <Border Grid.Column="4" Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1"
                                            CornerRadius="4" Padding="5,0" Margin="6,0,4,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DamageText}" Foreground="{Binding DamageBrush}"
                                                   FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.4:10'}"/>
                                    </Border>
                                    <Border Grid.Column="5" Background="{DynamicResource Skin.StatBg}" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1"
                                            CornerRadius="4" Padding="5,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PercentText}" Foreground="{Binding PercentBrush}" MinWidth="40" TextAlignment="Right"
                                                   FontSize="{Binding RowHeight, Converter={StaticResource FontSize}, ConverterParameter='0.4:10'}"/>
                                    </Border>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding BarRatio, Converter={StaticResource RatioToStar}}"/>
                                        <ColumnDefinition Width="{Binding BarRest, Converter={StaticResource RatioToStar}}"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding FillBrush}" CornerRadius="1"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>
            </ScrollViewer>

            <!-- combat-timer pill (React CombatTimer.tsx): below the rows -->
            <Border Grid.Row="3" CornerRadius="6" Padding="8,3" Margin="0,6,0,0"
                    Background="{DynamicResource Skin.RowBg}" BorderBrush="{DynamicResource Skin.SoftBorder}" BorderThickness="1"
                    Visibility="{Binding CombatTimerVisibility}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding CombatStatusBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding CombatStatusText}" Foreground="{Binding CombatStatusBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding Duration}" Foreground="{Binding CombatTimeBrush}" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="4" Text="{Binding Status}" Foreground="{DynamicResource Skin.MutedFg}" FontSize="10" Margin="0,6,0,0"/>
        </Grid>
    </Border>
</Window>
