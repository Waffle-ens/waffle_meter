<Window x:Class="WaffleMeter.App.Wpf.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="waffle_meter"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Left="40" Top="40"
        FontFamily="Segoe UI">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="설정" Click="OnSettings"/>
            <MenuItem Header="종료" Click="OnExit"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Border Background="#CC1E1E1E" CornerRadius="6" Padding="8" MinWidth="380"
            MouseLeftButtonDown="OnDragHandle">
        <StackPanel>
            <DockPanel LastChildFill="False" Margin="0,0,0,6">
                <TextBlock Text="{Binding TargetName}" Foreground="#FFEEEEEE" FontWeight="Bold" FontSize="13"/>
                <TextBlock Text="{Binding Duration}" Foreground="#FFBBBBBB" DockPanel.Dock="Right"/>
            </DockPanel>
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="54"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#FFEEEEEE" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1" Text="{Binding Job}" Foreground="#FF9CDCFE"/>
                            <TextBlock Grid.Column="2" Text="{Binding Amount}" Foreground="#FFEEEEEE" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding Dps}" Foreground="#FFD7BA7D" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="4" Text="{Binding Contribution}" Foreground="#FFBBBBBB" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding Status}" Foreground="#FF888888" FontSize="10" Margin="0,6,0,0"/>
        </StackPanel>
    </Border>
</Window>
