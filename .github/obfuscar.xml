<?xml version="1.0" encoding="utf-8"?>
<!--
  Obfuscar (MIT) config for the release anti-analysis pass. Run in CI AFTER publish and BEFORE sign/pack,
  in place over the publish/ folder. OFF by default — enable with repo variable OBFUSCATE=true and TEST a
  release before relying on it. See docs/replay-feature-plan.md §7.

  Scope rationale:
   - Only rename-safe, non-WPF WaffleMeter libraries are listed. WaffleMeter.App.Wpf is EXCLUDED (BAML/XAML
     + StartupObject resolved by name). WaffleMeter.Stats is EXCLUDED (its DTOs serialize by name via
     System.Text.Json — renaming would break the web contract).
   - KeepPublicApi=true: the un-obfuscated App.Wpf references these assemblies' public API by name, so public
     members are preserved; internal/private members are renamed and string literals (opcode names, paths,
     the reverse-engineered movement constants as strings) are encrypted via HideStrings.
   - For stronger protection (numeric constant encryption + control-flow flattening) ConfuserEx2 would be
     needed, scoped to WaffleMeter.Replay.dll alone, gated on a live smoke test (.NET 10 support unproven).
-->
<Obfuscator>
  <Var name="InPath" value="publish" />
  <Var name="OutPath" value="publish" />
  <Var name="KeepPublicApi" value="true" />
  <Var name="HidePrivateApi" value="true" />
  <Var name="HideStrings" value="true" />
  <Var name="RenameProperties" value="true" />
  <Var name="RenameEvents" value="true" />
  <Var name="RenameFields" value="true" />
  <Var name="ReuseNames" value="true" />
  <Var name="UseUnicodeNames" value="false" />
  <Var name="OptimizeMethods" value="true" />

  <!-- The private replay logic (reverse-engineered movement layout) — the primary hardening target. -->
  <Module file="$(InPath)\WaffleMeter.Replay.dll" />
  <!-- The packet parser core + data layer (opcode handling, identity). -->
  <Module file="$(InPath)\WaffleMeter.Capture.dll" />
  <Module file="$(InPath)\WaffleMeter.Data.dll" />
  <Module file="$(InPath)\WaffleMeter.App.Core.dll" />
</Obfuscator>
